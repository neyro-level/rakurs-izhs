---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { routeMapSections, sitePages } from '@/data/navigation';
---

<BaseLayout title="Карта сайта" description="Актуальная карта сайта Ракурс ИЖС: разделы главной страницы и служебные страницы проекта." noindex>
  <div class="site-container py-16 md:py-24">
    <h1 class="text-3xl md:text-4xl font-bold text-[var(--color-text-primary)]">Карта сайта</h1>

    <div class="mt-10 grid gap-8 md:grid-cols-2">
      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-tertiary)] mb-4">Разделы лендинга</h2>
        <ul class="space-y-3">
          {routeMapSections.map((section) => (
            <li>
              <a href={section.href} class="group flex flex-col gap-0.5">
                <span class="text-base font-medium text-[var(--color-text-primary)] group-hover:text-[var(--color-accent-primary)] transition-colors">{section.title}</span>
                <span class="text-sm text-[var(--color-text-secondary)]">{section.desc}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-tertiary)] mb-4">Страницы</h2>
        <ul class="space-y-3">
          {sitePages.map((page) => (
            <li>
              <a href={page.href} class="text-base font-medium text-[var(--color-text-primary)] hover:text-[var(--color-accent-primary)] transition-colors">{page.title}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</BaseLayout>
