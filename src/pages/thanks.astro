---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { COMPANY, EXPERT, SITE } from '@/lib/constants';

const url = Astro.url;
const method = url.searchParams.get('method') ?? 'default';

const methodLabels: Record<string, string> = {
  call: 'позвонит вам',
  telegram: 'напишет вам в Telegram',
  max: 'напишет вам в Max',
  default: 'свяжется с вами',
};

const contactLabel = methodLabels[method] ?? methodLabels.default;
const phoneHref = `tel:${COMPANY.officePhone.replace(/[^\d+]/g, '')}`;
const telegramHref = `https://t.me/${EXPERT.telegram.replace('@', '')}`;
---

<BaseLayout
  title="Заявка принята — Ракурс ИЖС"
  description="Заявка на разбор строительства принята. Специалист Ракурс свяжется с вами и уточнит следующий шаг."
  canonical={`${SITE.url}/thanks/`}
  noindex={true}
>
  <main class="bg-[var(--color-bg-primary)]">
    <section class="relative overflow-hidden bg-[var(--color-bg-dark)] text-[var(--color-text-ondark)]">
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(91,199,242,0.14),transparent_30%),linear-gradient(180deg,rgba(255,255,255,0.03),transparent)]"
        aria-hidden="true"
      />
      <div
        class="pointer-events-none absolute inset-0 opacity-[0.04]"
        aria-hidden="true"
        style="background-image: linear-gradient(rgba(255,255,255,1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,1) 1px, transparent 1px); background-size: 48px 48px;"
      />

      <div class="site-container relative py-24 md:py-32">
        <div class="mx-auto max-w-3xl text-center">
          <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-full border border-[var(--color-border-ondark)] bg-[rgba(255,255,255,0.05)] shadow-[0_18px_40px_-24px_rgba(0,0,0,0.42)]">
            <svg
              width="34"
              height="34"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-[var(--color-accent-cyan)]"
              aria-hidden="true"
            >
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
              <polyline points="22 4 12 14.01 9 11.01" />
            </svg>
          </div>

          <p class="mt-8 text-xs font-semibold uppercase tracking-[0.08em] text-[var(--color-accent-cyan)]">
            Заявка принята
          </p>

          <h1 class="mt-5 text-[34px] font-bold leading-[1.08] tracking-[-0.02em] text-[var(--color-text-ondark)] md:text-[48px]">
            Разбор строительства получен
          </h1>

          <p class="mx-auto mt-5 max-w-[46ch] text-base leading-relaxed text-[var(--color-text-ondark-mute)] md:text-lg">
            {EXPERT.name} или специалист Ракурс {contactLabel}, чтобы уточнить ситуацию по участку,
            ипотеке, смете и предложить понятный следующий шаг.
          </p>

          <div class="mt-8 inline-flex items-center gap-2 rounded-full border border-[var(--color-border-ondark)] bg-[rgba(255,255,255,0.05)] px-4 py-2 text-sm text-[var(--color-text-ondark-mute)]">
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-[var(--color-accent-cyan)]"
              aria-hidden="true"
            >
              <path d="M12 8v4l3 3" />
              <circle cx="12" cy="12" r="10" />
            </svg>
            Обычно отвечаем в ближайшее рабочее время
          </div>

          <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
            <a
              href="/"
              class="inline-flex min-h-[48px] w-full items-center justify-center rounded-[var(--radius-md)] bg-white px-7 py-4 text-base font-semibold text-[var(--color-bg-dark)] transition-colors hover:bg-[var(--color-bg-secondary)] sm:w-auto"
            >
              Вернуться на главную
            </a>
            <a
              href={phoneHref}
              class="inline-flex min-h-[48px] w-full items-center justify-center rounded-[var(--radius-md)] border border-[var(--color-border-ondark)] px-7 py-4 text-base font-medium text-[var(--color-text-ondark)] transition-colors hover:bg-white/5 sm:w-auto"
            >
              Позвонить в офис
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="vn-section-padding">
      <div class="site-container">
        <div class="grid-12 gap-y-8 lg:gap-y-0">
          <div class="col-span-12 lg:col-span-4">
            <div class="rounded-[var(--radius-2xl)] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_20px_48px_-36px_rgba(7,27,58,0.18)] sm:p-8">
              <span class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.06em] text-[var(--color-accent-primary)]">
                <span class="block h-px w-6 bg-[var(--color-accent-primary)]" />
                Что дальше
              </span>

              <h2 class="mt-5 text-[28px] font-bold leading-[1.14] tracking-[-0.01em] text-[var(--color-text-primary)] md:text-[34px]">
                Следующий шаг уже понятен
              </h2>

              <p class="mt-4 text-base leading-relaxed text-[var(--color-text-secondary)]">
                Мы не переводим заявку в хаос. Сначала собираем вводные, потом даём понятный маршрут:
                участок, ипотека, подрядчик, смета.
              </p>
            </div>
          </div>

          <div class="col-span-12 lg:col-span-8 lg:pl-8">
            <div class="grid grid-cols-1 gap-5 md:grid-cols-3">
              <article class="rounded-[var(--radius-2xl)] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_18px_44px_-36px_rgba(7,27,58,0.18)]">
                <span class="text-sm font-semibold tracking-[0.08em] text-[var(--color-accent-primary)]">01</span>
                <h3 class="mt-4 text-lg font-semibold text-[var(--color-text-primary)]">Уточним вашу ситуацию</h3>
                <p class="mt-3 text-sm leading-[1.65] text-[var(--color-text-secondary)]">
                  Поймём, на каком вы этапе: ищете участок, нужна ипотека, сравниваете сметы или выбираете подрядчика.
                </p>
              </article>

              <article class="rounded-[var(--radius-2xl)] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_18px_44px_-36px_rgba(7,27,58,0.18)]">
                <span class="text-sm font-semibold tracking-[0.08em] text-[var(--color-accent-primary)]">02</span>
                <h3 class="mt-4 text-lg font-semibold text-[var(--color-text-primary)]">Разберём риски до договора</h3>
                <p class="mt-3 text-sm leading-[1.65] text-[var(--color-text-secondary)]">
                  Проверим, где может сломаться сценарий: лимит по ипотеке, участок, смета, аккредитация подрядчика, скрытые доплаты.
                </p>
              </article>

              <article class="rounded-[var(--radius-2xl)] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_18px_44px_-36px_rgba(7,27,58,0.18)]">
                <span class="text-sm font-semibold tracking-[0.08em] text-[var(--color-accent-primary)]">03</span>
                <h3 class="mt-4 text-lg font-semibold text-[var(--color-text-primary)]">Дадим понятный маршрут</h3>
                <p class="mt-3 text-sm leading-[1.65] text-[var(--color-text-secondary)]">
                  После разговора у вас будет не общая консультация, а конкретный следующий шаг по вашему сценарию строительства.
                </p>
              </article>
            </div>

            <div class="mt-6 rounded-[var(--radius-2xl)] border border-[var(--color-border)] bg-[var(--color-bg-surface-low)] p-6 sm:p-7">
              <h3 class="text-base font-semibold text-[var(--color-text-primary)]">Контакты Ракурс</h3>
              <div class="mt-4 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
                <a
                  href={phoneHref}
                  class="inline-flex items-center gap-2 text-sm font-medium text-[var(--color-accent-primary)] transition-colors hover:text-[var(--color-accent-hover)]"
                >
                  {COMPANY.officePhone}
                </a>
                <a
                  href={telegramHref}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 text-sm font-medium text-[var(--color-accent-primary)] transition-colors hover:text-[var(--color-accent-hover)]"
                >
                  {EXPERT.telegram}
                </a>
                <a
                  href={EXPERT.max}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 text-sm font-medium text-[var(--color-accent-primary)] transition-colors hover:text-[var(--color-accent-hover)]"
                >
                  Max
                </a>
              </div>
              <p class="mt-4 text-sm leading-[1.65] text-[var(--color-text-tertiary)]">
                {COMPANY.legalName}, ИНН {COMPANY.inn}. {COMPANY.address}
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
