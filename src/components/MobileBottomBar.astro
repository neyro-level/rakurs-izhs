---
import { EXPERT } from '@/lib/constants';
---

<div class="fixed bottom-0 left-0 right-0 z-[90] md:hidden bg-[var(--color-bg-dark)]/95 backdrop-blur-xl border-t border-[var(--color-border-ondark)]">
  <div class="site-container flex items-center justify-between gap-3 py-3">
    <a
      href={`tel:${EXPERT.phone.replace(/\s/g, '')}`}
      class="flex items-center justify-center gap-2 rounded-[var(--radius-md)] border border-[var(--color-border-ondark)] text-[var(--color-text-ondark)] px-4 py-3 text-sm font-medium"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
      </svg>
      Позвонить
    </a>
    <button
      type="button"
      data-open-modal
      class="flex-1 inline-flex items-center justify-center rounded-[var(--radius-md)] bg-white text-[var(--color-bg-dark)] px-4 py-3 text-sm font-medium hover:bg-[var(--color-bg-secondary)] transition-colors"
    >
      Понять, с чего начать
    </button>
  </div>
</div>
