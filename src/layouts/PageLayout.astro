---
import BaseLayout from './BaseLayout.astro';
import Footer from '@/components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  schema?: object | object[];
}

const props = Astro.props;
---

<BaseLayout {...props}>
  <main>
    <slot />
  </main>
  <Footer />
</BaseLayout>
