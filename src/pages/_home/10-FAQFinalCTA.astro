---
import { homeFaqItems as faqs } from '@/data/home-faq';
---

<section id="section-faq" class="relative overflow-hidden bg-[var(--color-bg-surface)] vn-section-padding">
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(8,116,196,0.08),transparent_30%),radial-gradient(circle_at_bottom_right,rgba(91,199,242,0.08),transparent_26%)]"
    aria-hidden="true"
  />

  <div class="site-container relative">
    <div class="grid-12 items-start gap-y-8 lg:gap-y-0">
      <div class="col-span-12 lg:col-span-4">
        <div class="rounded-[var(--radius-2xl)] border border-[var(--color-border)] bg-[var(--color-bg-primary)] p-6 sm:p-8 lg:sticky lg:top-24 shadow-[0_24px_56px_-40px_rgba(7,27,58,0.14)]">
          <span class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.06em] text-[var(--color-accent-primary)]">
            <span class="block h-px w-6 bg-[var(--color-accent-primary)]" />
            Важные вопросы перед стартом
          </span>

          <h2 class="mt-5 text-[28px] font-bold leading-[1.14] tracking-[-0.01em] text-[var(--color-text-primary)] md:text-[36px] lg:text-[40px]">
            Что обычно останавливает перед стартом стройки
            <span class="block">и как мы это проверяем заранее</span>
          </h2>

          <p class="mt-4 max-w-[34ch] text-base leading-relaxed text-[var(--color-text-secondary)] md:text-lg">
            Дом по семейной ипотеке 6% начинается не с договора, а с правильных ответов: по участку, банку, подрядчику, смете и следующему шагу.
          </p>
        </div>
      </div>

      <div class="col-span-12 lg:col-span-8 lg:pl-8">
        <div class="space-y-4 md:space-y-5">
          {faqs.map((faq, i) => (
            <details
              class="faq-item group overflow-hidden rounded-[var(--radius-2xl)] border border-[var(--color-border)] bg-[var(--color-bg-surface)] shadow-[0_20px_48px_-40px_rgba(7,27,58,0.18)] transition-all duration-200 hover:border-[var(--color-border-strong)]"
            >
              <summary class="faq-trigger grid list-none grid-cols-[auto_1fr_auto] items-start gap-4 px-5 py-5 text-left sm:px-6 sm:py-6 md:gap-5">
                <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-[var(--radius-md)] bg-[var(--color-accent-soft)] text-sm font-semibold text-[var(--color-accent-primary)]">
                  {String(i + 1).padStart(2, '0')}
                </span>

                <span class="pt-1 text-base font-semibold leading-snug text-[var(--color-text-primary)] md:text-lg">
                  {faq.question}
                </span>

                <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-[var(--color-border)] text-[var(--color-text-tertiary)] transition-colors duration-200 group-hover:border-[var(--color-border-strong)] group-hover:text-[var(--color-accent-primary)]">
                  <svg
                    class="faq-icon transition-transform duration-300"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <line x1="12" y1="5" x2="12" y2="19" />
                    <line x1="5" y1="12" x2="19" y2="12" />
                  </svg>
                </span>
              </summary>

              <div class="faq-content px-5 pb-5 sm:px-6 sm:pb-6">
                <div class="rounded-[var(--radius-xl)] bg-[var(--color-bg-surface-low)] px-4 py-4 sm:px-5 sm:py-5 md:ml-[4rem]">
                  <p class="text-sm leading-[1.65] text-[var(--color-text-secondary)] md:text-base">
                    {faq.answer}
                  </p>
                </div>
              </div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Final CTA -->
<section id="section-final-cta" class="bg-[var(--color-bg-dark)] vn-section-padding relative overflow-hidden">
  <!-- Static gradient background -->
  <div class="absolute inset-0 opacity-20" aria-hidden="true">
    <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-accent-primary)] via-transparent to-[var(--color-accent-cyan)]"></div>
  </div>

  <!-- Decorative grid -->
  <div class="absolute inset-0 opacity-[0.03]" aria-hidden="true"
    style="background-image: linear-gradient(rgba(255,255,255,1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,1) 1px, transparent 1px); background-size: 48px 48px;"
  />

  <div class="site-container relative">
    <div class="fade-in-up max-w-3xl mx-auto text-center">
      
      <h2 class="text-[28px] md:text-[36px] lg:text-[42px] font-bold leading-[1.14] tracking-[-0.01em] text-[var(--color-text-ondark)]">
        Перед тем как подписывать договор со строителем,<br class="hidden md:block" />
        <span class="text-[var(--color-accent-cyan)]">разберите смету, участок и ипотеку</span>
      </h2>

      <p class="mt-4 text-base md:text-lg text-[var(--color-text-ondark-mute)] leading-relaxed max-w-[52ch] mx-auto">
        Получите понятный план действий от эксперта по ИЖС. Без обязательств и давления.
      </p>

      <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
        <button
          type="button"
          data-open-modal
          data-scenario="dont_know"
          class="w-full sm:w-auto inline-flex items-center justify-center rounded-[var(--radius-md)] bg-[var(--color-accent-primary)] text-white px-8 py-4 text-base font-semibold hover:bg-[var(--color-accent-hover)] transition-colors min-h-[48px] shadow-[0_4px_16px_-4px_rgba(8,116,196,0.4)]"
        >
          Получить разбор строительства
        </button>
      </div>

      <p class="mt-4 text-sm text-[var(--color-text-ondark-soft)]">
        Бесплатная консультация. Без обязательств.
      </p>

    </div>
  </div>
</section>

<style>
  .faq-trigger::-webkit-details-marker {
    display: none;
  }

  .faq-item[open] {
    border-color: var(--color-border-strong);
    box-shadow: 0 24px 56px -40px rgba(7, 27, 58, 0.22);
  }

  .faq-item[open] .faq-icon {
    transform: rotate(45deg);
  }

  .faq-item[open] .faq-trigger > span:nth-child(3) {
    border-color: color-mix(in srgb, var(--color-accent-primary) 22%, var(--color-border));
    color: var(--color-accent-primary);
  }

  @media (max-width: 767px) {
    .faq-content > div {
      margin-left: 0 !important;
    }
  }
</style>
