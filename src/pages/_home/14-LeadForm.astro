---
import { EXPERT } from '@/lib/constants';

const stages = [
  'Только думаем о доме',
  'Нужна ипотека',
  'Ищем участок',
  'Участок есть',
  'Есть сметы',
  'Не знаем, с чего начать',
];

const budgets = [
  'до 3 млн ₽',
  '3–5 млн ₽',
  '5–7 млн ₽',
  '7–10 млн ₽',
  '10–15 млн ₽',
  'более 15 млн ₽',
];
---

<section id="section-lead-form" class="bg-[var(--color-bg-secondary)] vn-section-padding">
  <div class="site-container">
    <div class="mx-auto max-w-2xl rounded-[var(--radius-xl)] bg-[var(--color-bg-surface)] p-6 md:p-10 shadow-[0_4px_20px_rgba(7,27,58,0.06)]">
      <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-text-primary)] text-center">
        Расскажите, на каком этапе вы сейчас
      </h2>
      <p class="mt-3 text-center text-[var(--color-text-secondary)]">
        {EXPERT.name} уточнит вашу ситуацию и подскажет следующий шаг: ипотека, участок, подрядчик, смета или проверка уже выбранного варианта.
      </p>

      <form
        class="mt-8 space-y-5"
        action="/thanks/"
        method="GET"
      >
        <div class="grid gap-5 md:grid-cols-2">
          <div>
            <label for="lf-name" class="block text-sm font-medium text-[var(--color-text-primary)]">Имя</label>
            <input id="lf-name" name="name" type="text" required class="mt-1 w-full rounded-[var(--radius-sm)] border border-[var(--color-border)] bg-white px-4 py-3 text-base text-[var(--color-text-primary)] focus:border-[var(--color-accent-primary)] focus:outline-none focus:ring-[3px] focus:ring-[var(--color-accent-cta-soft)]" placeholder="Ваше имя" />
          </div>
          <div>
            <label for="lf-phone" class="block text-sm font-medium text-[var(--color-text-primary)]">Телефон</label>
            <input id="lf-phone" name="phone" type="tel" required class="mt-1 w-full rounded-[var(--radius-sm)] border border-[var(--color-border)] bg-white px-4 py-3 text-base text-[var(--color-text-primary)] focus:border-[var(--color-accent-primary)] focus:outline-none focus:ring-[3px] focus:ring-[var(--color-accent-cta-soft)]" placeholder="+7 (___) ___-__-__" />
          </div>
        </div>

        <div class="grid gap-5 md:grid-cols-2">
          <div>
            <label for="lf-stage" class="block text-sm font-medium text-[var(--color-text-primary)]">На каком вы этапе?</label>
            <select id="lf-stage" name="stage" required class="mt-1 w-full rounded-[var(--radius-sm)] border border-[var(--color-border)] bg-white px-4 py-3 text-base text-[var(--color-text-primary)] focus:border-[var(--color-accent-primary)] focus:outline-none focus:ring-[3px] focus:ring-[var(--color-accent-cta-soft)]">
              <option value="">Выберите этап</option>
              {stages.map((s) => <option value={s}>{s}</option>)}
            </select>
          </div>
          <div>
            <label for="lf-budget" class="block text-sm font-medium text-[var(--color-text-primary)]">Примерный бюджет</label>
            <select id="lf-budget" name="budget" class="mt-1 w-full rounded-[var(--radius-sm)] border border-[var(--color-border)] bg-white px-4 py-3 text-base text-[var(--color-text-primary)] focus:border-[var(--color-accent-primary)] focus:outline-none focus:ring-[3px] focus:ring-[var(--color-accent-cta-soft)]">
              <option value="">Не уверен</option>
              {budgets.map((b) => <option value={b}>{b}</option>)}
            </select>
          </div>
        </div>

        <div>
          <label for="lf-comment" class="block text-sm font-medium text-[var(--color-text-primary)]">Комментарий</label>
          <textarea id="lf-comment" name="comment" rows="3" class="mt-1 w-full rounded-[var(--radius-sm)] border border-[var(--color-border)] bg-white px-4 py-3 text-base text-[var(--color-text-primary)] focus:border-[var(--color-accent-primary)] focus:outline-none focus:ring-[3px] focus:ring-[var(--color-accent-cta-soft)]" placeholder="Можно коротко описать ситуацию своими словами..."></textarea>
        </div>

        <label class="flex items-start gap-3 cursor-pointer">
          <input type="checkbox" required class="mt-0.5 h-4 w-4 accent-[var(--color-accent-primary)]" />
          <span class="text-xs text-[var(--color-text-secondary)]">
            Согласен на обработку персональных данных.{' '}
            <a href="/privacy/" class="text-[var(--color-accent-primary)] hover:underline">Политика конфиденциальности</a>{' '}
            и <a href="/soglasie/" class="text-[var(--color-accent-primary)] hover:underline">согласие</a>.
          </span>
        </label>

        <button
          type="submit"
          class="w-full rounded-[var(--radius-md)] bg-[var(--color-accent-primary)] px-7 py-4 text-base font-medium text-white hover:bg-[var(--color-accent-hover)] transition-colors"
        >
          Понять, с чего начать
        </button>

        <p class="text-center text-xs text-[var(--color-text-tertiary)]">
          Можно коротко описать ситуацию своими словами. Артемий уточнит детали в разговоре.
        </p>
      </form>
    </div>
  </div>
</section>
