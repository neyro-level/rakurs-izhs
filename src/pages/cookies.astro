<script>
  (function () {
    const confirmEl = document.getElementById('vn-cookies-confirm');
    if (!confirmEl) return;

    document.querySelectorAll('.vn-cookies-manage__btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const value = btn.getAttribute('data-consent');
        if (value === 'accepted' || value === 'rejected') {
          localStorage.setItem('vn_cookie_consent', value);
          window.dispatchEvent(new Event('storage'));
          confirmEl.textContent = value === 'accepted'
            ? 'Согласие принято. Аналитические cookie включены.'
            : 'Согласие обновлено. Используются только технические cookie.';
        }
      });
    });
  })();
</script>
