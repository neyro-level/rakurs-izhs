---
import { EXPERT, SITE } from '@/lib/constants';

const navLinks = [
  { label: 'Проверить ипотеку 6%', href: '#mortgage' },
  { label: 'Разобрать смету', href: '#estimate' },
  { label: 'Выбрать строителя', href: '#contractors' },
];
---

<header id="site-header" class="sticky top-0 z-[100] bg-[var(--color-bg-dark)]/85 backdrop-blur-xl border-b border-transparent transition-colors duration-200">
  <div class="site-container flex items-center justify-between h-16 md:h-[72px]">
    <a href="/" class="flex items-center" aria-label={`${SITE.shortName} — на главную`}>
      <img
        src="/logo_rakurs_izhs_white.png"
        alt={SITE.shortName}
        width="180"
        height="48"
        class="h-12 md:h-14 w-auto"
      />
    </a>

    <nav class="hidden lg:flex items-center gap-7" aria-label="Основная навигация">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-[15px] font-medium text-[var(--color-text-ondark-mute)] hover:text-[var(--color-text-ondark)] transition-colors"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-4">
      <a
        href={`tel:${EXPERT.phone.replace(/\s/g, '')}`}
        class="hidden md:inline-flex text-sm font-semibold text-[var(--color-text-ondark)] hover:text-[var(--color-accent-cyan)] transition-colors"
      >
        {EXPERT.phone}
      </a>
      <button
        type="button"
        data-open-modal
        class="hidden md:inline-flex items-center justify-center rounded-[var(--radius-md)] bg-white text-[var(--color-bg-dark)] px-5 py-2.5 text-sm font-medium hover:bg-[var(--color-bg-secondary)] transition-colors"
      >
        Понять, с чего начать
      </button>
      <button
        type="button"
        id="mobile-menu-toggle"
        class="lg:hidden flex flex-col justify-center items-center gap-[5px] w-11 h-11 bg-transparent border-0 cursor-pointer"
        aria-label="Открыть меню"
        aria-expanded="false"
      >
        <span class="w-[22px] h-0.5 bg-white rounded-full transition-transform" />
        <span class="w-[22px] h-0.5 bg-white rounded-full transition-opacity" />
        <span class="w-[22px] h-0.5 bg-white rounded-full transition-transform" />
      </button>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const onScroll = () => {
    if (header) header.classList.toggle('border-[var(--color-border-ondark)]', window.scrollY > 8);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
