---
import '@/styles/global.css';
import { SITE } from '@/lib/constants';
import { getSeoEntry } from '@/lib/seo/registry';
import Header from '@/components/Header.astro';
import RouteMapOverlay from '@/components/RouteMapOverlay.astro';
import MobileBottomCTA from '@/components/MobileBottomCTA.astro';
import ReviewWidget from '@/components/shared/ReviewWidget';
import ModalShell from '@/components/shared/ModalShell';
import CookieBanner from '@/components/shared/CookieBanner';
import '@/styles/review.css';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  ogImage?: string;
  canonical?: string;
  schema?: object | object[];
}

const {
  title,
  description = SITE.description,
  noindex = false,
  ogImage,
  canonical,
  schema,
} = Astro.props;

const registryEntry = getSeoEntry(Astro.url.pathname);
const resolvedTitle = title || registryEntry?.title || SITE.shortName;
const resolvedDescription = description || registryEntry?.description || SITE.description;
const resolvedNoindex = noindex || registryEntry?.noindex || false;
const canonicalURL =
  canonical || registryEntry?.canonical || new URL(Astro.url.pathname, Astro.site || SITE.url).toString();
const fullTitle = resolvedTitle.includes(SITE.shortName) ? resolvedTitle : `${resolvedTitle} — ${SITE.shortName}`;
const resolvedOgImage = ogImage || registryEntry?.ogImage || `${SITE.url}/og/rakurs-izhs-default.png`;
const showMobileCTA = Astro.url.pathname === '/';
const ymCounterId = import.meta.env.PUBLIC_YM_COUNTER_ID;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={resolvedDescription} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content={resolvedNoindex ? 'noindex, nofollow' : 'index, follow'} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:site_name" content={SITE.shortName} />
    <meta property="og:image" content={resolvedOgImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="alternate" type="text/plain" href="/llms.txt" />
    {ymCounterId && <meta name="ym-counter-id" content={ymCounterId} />}

    {ymCounterId && (
      <script is:inline define:vars={{ ymCounterId }}>
        (function() {
          if (window.__rakursAnalyticsBootstrapReady) return;
          window.__rakursAnalyticsBootstrapReady = true;

          window.rakursInitAnalytics = function() {
            if (window.__rakursYmScriptInjected) {
              window.__rakursAnalyticsReady = true;
              window.dispatchEvent(new CustomEvent('rakurs:analytics-ready'));
              return;
            }

            const existingScript = document.getElementById('rakurs-ym-partytown');
            if (existingScript) {
              window.__rakursYmScriptInjected = true;
              window.__rakursAnalyticsReady = true;
              window.dispatchEvent(new CustomEvent('rakurs:analytics-ready'));
              return;
            }

            const counterLiteral = JSON.stringify(ymCounterId);
            const analyticsScript = document.createElement('script');
            analyticsScript.id = 'rakurs-ym-partytown';
            analyticsScript.type = 'text/partytown';
            analyticsScript.text = `
window.ym = window.ym || function(){(window.ym.a = window.ym.a || []).push(arguments);};
window.ym.l = 1 * new Date();
(function(m,e,t,r,i,k,a){for(var j=0;j<document.scripts.length;j++){if(document.scripts[j].src===r){return;}}k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a);})(window,document,"script","https://mc.yandex.ru/metrika/tag.js","ym");
ym(${counterLiteral},"init",{clickmap:true,trackLinks:true,accurateTrackBounce:true,webvisor:true});
`;
            document.head.appendChild(analyticsScript);
            window.__rakursYmScriptInjected = true;
            window.__rakursAnalyticsReady = true;
            window.dispatchEvent(new CustomEvent('ptupdate'));
            window.dispatchEvent(new CustomEvent('rakurs:analytics-ready'));
          };

          try {
            if (window.localStorage.getItem('rakurs_cookie_consent') === 'accepted') {
              window.rakursInitAnalytics();
            }
          } catch {}
        })();
      </script>
    )}

    {schema && <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />}
  </head>

  <body class="min-h-screen antialiased">
    <Header />
    <RouteMapOverlay />
    <slot />
    {showMobileCTA && <MobileBottomCTA />}
    <ReviewWidget client:load />
    <ModalShell client:load />
    <CookieBanner client:idle />

    <script>
      import { initScrollDepthTracking, track } from '@/lib/analytics';

      const bridgeWindow = window as Window & {
        __rakursModalBridgeInitialized?: boolean;
        __rakursPendingModalOpen?: { scenario?: string };
      };

      function normalizeTrackingLabel(value: string) {
        return value.replace(/\s+/g, ' ').trim().slice(0, 120);
      }

      initScrollDepthTracking();

      (function() {
        if (bridgeWindow.__rakursModalBridgeInitialized) return;
        bridgeWindow.__rakursModalBridgeInitialized = true;

        document.addEventListener('click', function(event) {
          const target = event.target;
          if (!(target instanceof Element)) return;

          const trigger = target.closest('[data-open-modal]');
          if (!(trigger instanceof HTMLElement)) return;

          event.preventDefault();

          track('cta_click', {
            scenario: trigger.dataset.scenario || 'dont_know',
            label: normalizeTrackingLabel(
              trigger.dataset.analyticsLabel
              || trigger.getAttribute('aria-label')
              || trigger.textContent
              || ''
            ),
            kind: 'modal_trigger',
          });

          const detail = {
            scenario: trigger.dataset.scenario || undefined,
          };

          bridgeWindow.__rakursPendingModalOpen = detail;
          window.dispatchEvent(new CustomEvent('rakurs:open-modal', { detail }));
        });

        document.addEventListener('click', function(event) {
          const target = event.target;
          if (!(target instanceof Element)) return;

          const phoneLink = target.closest('a[href^="tel:"]');
          if (phoneLink instanceof HTMLAnchorElement) {
            track('phone_click', {
              label: normalizeTrackingLabel(
                phoneLink.getAttribute('aria-label')
                || phoneLink.textContent
                || phoneLink.getAttribute('href')
                || ''
              ),
              phone: phoneLink.getAttribute('href')?.replace('tel:', '') || '',
            });
            return;
          }

          const messengerLink = target.closest('a[href*="t.me"], a[href*="max.ru"], a[href*="wa.me"]');
          if (messengerLink instanceof HTMLAnchorElement) {
            track('messenger_click', {
              label: normalizeTrackingLabel(
                messengerLink.getAttribute('aria-label')
                || messengerLink.textContent
                || messengerLink.href
              ),
              href: messengerLink.href,
            });
          }
        });

        document.addEventListener(
          'toggle',
          function(event) {
            const details = event.target;
            if (!(details instanceof HTMLDetailsElement)) return;
            if (!details.open || !details.matches('.faq-item')) return;

            const summary = details.querySelector('summary');
            const question = normalizeTrackingLabel(summary?.textContent || '');
            if (!question) return;

            track('faq_open', { question });
          },
          true
        );
      })();
    </script>

    <script>
      // ── Route Map Overlay controller ──
      (function() {
        const header = document.getElementById('site-header');
        const overlay = document.getElementById('route-map-overlay');
        const toggleBtn = document.querySelector('[data-nav-toggle]');
        const closeBtn = document.querySelector('[data-nav-close]');

        if (!overlay || !toggleBtn) return;

        let savedScrollY = 0;

        const openOverlay = () => {
          savedScrollY = window.scrollY;
          overlay.dataset.open = 'true';
          overlay.removeAttribute('inert');
          toggleBtn.setAttribute('aria-expanded', 'true');
          if (header) header.dataset.overlay = 'true';
          document.body.style.position = 'fixed';
          document.body.style.top = `-${savedScrollY}px`;
          document.body.style.width = '100%';
        };

        const closeOverlay = () => {
          overlay.dataset.open = 'false';
          overlay.setAttribute('inert', '');
          toggleBtn.setAttribute('aria-expanded', 'false');
          if (header) header.dataset.overlay = 'false';
          document.body.style.position = '';
          document.body.style.top = '';
          document.body.style.width = '';
          window.scrollTo(0, savedScrollY);
        };

        toggleBtn.addEventListener('click', () => {
          const isOpen = overlay.dataset.open === 'true';
          isOpen ? closeOverlay() : openOverlay();
        });

        if (closeBtn) {
          closeBtn.addEventListener('click', closeOverlay);
        }

        // Close on Escape
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && overlay.dataset.open === 'true') {
            closeOverlay();
          }
        });

        // Close on click outside cards (on the overlay background)
        overlay.addEventListener('click', (e) => {
          if (e.target === overlay) {
            closeOverlay();
          }
        });

        // Close overlay when clicking navigation links within the overlay
        overlay.querySelectorAll('a[href]').forEach((link) => {
          link.addEventListener('click', () => {
            closeOverlay();
          });
        });
      })();
    </script>
  </body>
</html>
