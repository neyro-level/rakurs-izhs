---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/lib/constants';

const url = Astro.url;
const method = url.searchParams.get('method') ?? 'default';

const methodLabels: Record<string, string> = {
  call:     'позвонит вам',
  telegram: 'напишет в Telegram',
  max:      'напишет в Max',
  default:  'свяжется с вами',
};
const contactLabel = methodLabels[method] ?? methodLabels.default;

const VK_VIDEO_URL = '[VK_VIDEO_EMBED_URL]';
const VK_VIDEO_TITLE = '[VK_VIDEO_TITLE]';
const TELEGRAM_CHANNEL = '[TELEGRAM_CHANNEL]';
const TELEGRAM_CHANNEL_NAME = '[TELEGRAM_CHANNEL_NAME]';
const showTelegram = TELEGRAM_CHANNEL !== '[TELEGRAM_CHANNEL]';
---

<BaseLayout
  title="Заявка принята — Ракурс ИЖС"
  description="Ваша заявка отправлена. Михаил свяжется с вами в течение 10 минут."
  canonical={`${SITE.url}/thanks/`}
  ogImage={`${SITE.url}/og/home.jpg`}
  noindex={true}
>
  <!-- ═══ Block 1: Confirmation ═══ -->
  <section class="vn-thanks-confirm">
    <div class="vn-container" style="text-align: center;">
      <div class="vn-thanks-checkmark">
        <span class="vn-thanks-checkmark__pulse" aria-hidden="true"></span>
        <span class="vn-thanks-checkmark__ring" aria-hidden="true">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="vn-thanks-checkmark__svg">
            <polyline class="vn-thanks-checkmark__path" points="20 6 9 17 4 12" />
          </svg>
        </span>
      </div>

      <p class="vn-thanks-eyebrow">ЗАЯВКА ПРИНЯТА</p>

      <h1 class="vn-thanks-h1">
        Михаил {contactLabel} в&nbsp;течение 10&nbsp;минут
      </h1>

      <p class="vn-thanks-subtitle">
        Помогаем военнослужащим в Пермье, Пермском крае и&nbsp;удалённо по всей России
      </p>

      <div class="vn-thanks-method">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 9.82 19.79 19.79 0 0 1 1.61 1.24 2 2 0 0 1 3.6 0h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 7.91a16 16 0 0 0 6.1 6.1l.88-.88a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.72 15.3"/>
        </svg>
        <span>Способ связи: {contactLabel}</span>
      </div>

      <div class="vn-thanks-divider" aria-hidden="true"></div>
    </div>
  </section>

  <!-- ═══ Block 2: Video ═══ -->
  <section class="vn-thanks-video">
    <div class="vn-container" style="text-align: center;">
      <p class="vn-thanks-eyebrow vn-thanks-eyebrow--center">ПОКА ЖДЁТЕ — ПОСМОТРИТЕ ЭТО</p>

      <p class="vn-thanks-video__subtitle">
        Михаил объясняет, как выбрать новостройку под военную ипотеку и не&nbsp;допустить типичных ошибок
      </p>

      {VK_VIDEO_URL !== '[VK_VIDEO_EMBED_URL]' ? (
        <div class="vn-thanks-video__wrap">
          <iframe
            src={VK_VIDEO_URL}
            title={VK_VIDEO_TITLE}
            allow="autoplay; encrypted-media; fullscreen; picture-in-picture; screen-wake-lock;"
            loading="lazy"
            allowfullscreen
          ></iframe>
        </div>
      ) : (
        <div class="vn-thanks-video__placeholder">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/>
            <line x1="9" x2="15" y1="9" y2="15"/>
            <line x1="15" x2="9" y1="9" y2="15"/>
          </svg>
          <p>Видео скоро появится</p>
        </div>
      )}
    </div>
  </section>

  <!-- ═══ Block 3: Next Steps ═══ -->
  <section class="vn-thanks-steps">
    <div class="vn-container">
      <h2 class="vn-thanks-steps__h2">Что произойдёт на&nbsp;разборе</h2>

      <div class="vn-grid-12 vn-thanks-steps__grid">
        <!-- Step 1 -->
        <div class="vn-thanks-step" style="grid-column: 1 / 5;">
          <div class="vn-thanks-step__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <circle cx="12" cy="12" r="6"/>
              <circle cx="12" cy="12" r="2"/>
            </svg>
          </div>
          <span class="vn-thanks-step__num">01</span>
          <h3 class="vn-thanks-step__title">Определим цель</h3>
          <p class="vn-thanks-step__body">Уточним вашу задачу: инвестиции, переезд или постоянное место жительства. Рассчитаем реальный бюджет с&nbsp;учётом военной ипотеки.</p>
        </div>

        <!-- Step 2 -->
        <div class="vn-thanks-step" style="grid-column: 5 / 9;">
          <div class="vn-thanks-step__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/>
              <path d="M3 10a2 2 0 0 1 .709-1.528l7-6a2 2 0 0 1 2.582 0l7 6A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            </svg>
          </div>
          <span class="vn-thanks-step__num">02</span>
          <h3 class="vn-thanks-step__title">Подберём объект</h3>
          <p class="vn-thanks-step__body">Покажем 2-3 подходящие новостройки в Пермье или Пермском крае с&nbsp;проверенными застройщиками и&nbsp;чистой юридической историей.</p>
        </div>

        <!-- Step 3 -->
        <div class="vn-thanks-step" style="grid-column: 9 / 13;">
          <div class="vn-thanks-step__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="6" cy="19" r="3"/>
              <path d="M9 19h8.5a3.5 3.5 0 0 0 0-7h-11a3.5 3.5 0 0 1 0-7H15"/>
              <circle cx="18" cy="5" r="3"/>
            </svg>
          </div>
          <span class="vn-thanks-step__num">03</span>
          <h3 class="vn-thanks-step__title">Построим маршрут</h3>
          <p class="vn-thanks-step__body">Расскажем пошаговый путь от заявки до сделки: документы, сроки, типичные подводные камни и&nbsp;как их избежать.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ Block 4: Telegram (conditional) ═══ -->
  {showTelegram && (
    <section class="vn-thanks-telegram">
      <div class="vn-container" style="text-align: center;">
        <svg class="vn-thanks-telegram__icon" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="m22 2-7 20-4-9-9-4 20-7z"/>
          <path d="M22 2 11 13"/>
        </svg>

        <h2 class="vn-thanks-telegram__h2">Подпишитесь на канал Михаила</h2>

        <p class="vn-thanks-telegram__body">
          Там — разборы новостроек, изменения в законе о военной ипотеке и&nbsp;реальные кейсы клиентов. Без воды и рекламы других застройщиков.
        </p>

        <a href={TELEGRAM_CHANNEL} target="_blank" rel="noopener noreferrer" class="vn-btn-primary vn-thanks-telegram__btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m22 2-7 20-4-9-9-4 20-7z"/>
            <path d="M22 2 11 13"/>
          </svg>
          Перейти в {TELEGRAM_CHANNEL_NAME || 'Telegram-канал'}
        </a>

        <p class="vn-thanks-telegram__micro">Без спама. Только по делу.</p>
      </div>
    </section>
  )}

  <!-- ═══ Block 5: Nav Strip ═══ -->
  <section class="vn-thanks-navstrip">
    <div class="vn-thanks-navstrip__inner">
      <a href="/" class="vn-thanks-navstrip__logo" aria-label="Ракурс ИЖС — на главную">
        <svg width="28" height="28" viewBox="0 0 40 40" fill="none" aria-hidden="true">
          <circle cx="20" cy="20" r="9" stroke="var(--color-text-ondark)" stroke-width="0.7" stroke-dasharray="2.2 2.2" opacity="0.3"/>
          <path d="M7 13 L7 7 L13 7" stroke="var(--color-text-ondark)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" opacity="0.7"/>
          <path d="M27 7 L33 7 L33 13" stroke="var(--color-text-ondark)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" opacity="0.7"/>
          <path d="M7 27 L7 33 L13 33" stroke="var(--color-text-ondark)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" opacity="0.7"/>
          <path d="M27 33 L33 33 L33 27" stroke="var(--color-text-ondark)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" opacity="0.7"/>
          <circle cx="20" cy="20" r="2.8" fill="var(--color-accent-cta)"/>
        </svg>
      </a>

      <nav class="vn-thanks-navstrip__links" aria-label="Навигация по сайту">
        <a href="/">Пермь</a>
        <span class="vn-thanks-navstrip__dot" aria-hidden="true">·</span>
        <span class="vn-thanks-navstrip__dot" aria-hidden="true">·</span>
        <a href="/etapy-pokupki/">Этапы покупки</a>
        <span class="vn-thanks-navstrip__dot" aria-hidden="true">·</span>
        <a href="/">На главную</a>
      </nav>
    </div>
  </section>

  <!-- ═══ Yandex.Metrika Goal ═══ -->
  <script is:inline>
    (function() {
      if (typeof window !== 'undefined' && window.ym && window.ymCounterId) {
        window.ym(window.ymCounterId, 'reachGoal', 'form_submitted');
      }
    })();
  </script>

  <style>
    /* ─── Block 1: Confirmation ─── */
    .vn-thanks-confirm {
      background-color: var(--color-bg-dark);
      color: var(--color-text-ondark);
      padding-top: 120px;
      padding-bottom: 64px;
    }

    .vn-thanks-checkmark {
      position: relative;
      width: 72px;
      height: 72px;
      margin: 0 auto 28px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .vn-thanks-checkmark__pulse {
      position: absolute;
      inset: 0;
      border-radius: 50%;
      background-color: var(--color-accent-cta);
      opacity: 0.6;
    }

    .vn-thanks-checkmark__ring {
      position: relative;
      width: 72px;
      height: 72px;
      border-radius: 50%;
      background-color: var(--color-accent-cta-soft);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--color-accent-cta);
    }

    .vn-thanks-checkmark__svg {
      width: 32px;
      height: 32px;
    }

    .vn-thanks-checkmark__path {
      stroke-dasharray: 30;
      stroke-dashoffset: 30;
    }

    .vn-thanks-eyebrow {
      font-size: var(--fs-label);
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--color-accent-cta);
      margin-bottom: 16px;
    }

    .vn-thanks-eyebrow--center {
      text-align: center;
    }

    .vn-thanks-h1 {
      font-size: var(--fs-h1);
      font-weight: 600;
      line-height: 1.15;
      color: var(--color-text-ondark);
      max-width: 640px;
      margin: 0 auto 20px;
      text-wrap: balance;
    }

    .vn-thanks-subtitle {
      font-size: var(--fs-lead);
      line-height: 1.6;
      color: var(--color-text-ondark-mute);
      max-width: 520px;
      margin: 0 auto 24px;
      text-wrap: pretty;
    }

    .vn-thanks-method {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 18px;
      background-color: color-mix(in srgb, var(--color-text-ondark) 6%, transparent);
      border: 1px solid var(--color-border-ondark);
      border-radius: var(--radius-full);
      font-size: var(--fs-body-sm);
      color: var(--color-text-ondark);
      opacity: 0.85;
    }

    .vn-thanks-method svg {
      flex-shrink: 0;
      opacity: 0.6;
    }

    .vn-thanks-divider {
      max-width: 120px;
      height: 1px;
      background-color: var(--color-border-ondark);
      margin: 48px auto 0;
    }

    /* ─── Block 2: Video ─── */
    .vn-thanks-video {
      background-color: var(--color-bg-dark);
      color: var(--color-text-ondark);
      padding-bottom: 120px;
    }

    .vn-thanks-video__subtitle {
      font-size: var(--fs-body);
      line-height: 1.6;
      color: var(--color-text-ondark-mute);
      max-width: 520px;
      margin: 0 auto 32px;
      text-wrap: pretty;
    }

    .vn-thanks-video__wrap {
      position: relative;
      width: 100%;
      max-width: 800px;
      margin: 0 auto;
      padding-bottom: 56.25%;
      border-radius: var(--radius-lg);
      overflow: hidden;
      background-color: var(--color-bg-dark-elev);
    }

    .vn-thanks-video__wrap iframe {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: 0;
      border-radius: inherit;
    }

    .vn-thanks-video__placeholder {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      padding: 64px 24px;
      max-width: 800px;
      margin: 0 auto;
      border: 1px dashed var(--color-border-ondark);
      border-radius: var(--radius-lg);
      color: var(--color-text-ondark);
      opacity: 0.35;
    }

    .vn-thanks-video__placeholder p {
      margin: 0;
      font-size: var(--fs-body);
    }

    /* ─── Block 3: Next Steps ─── */
    .vn-thanks-steps {
      background-color: var(--color-bg-secondary);
      padding-block: var(--spacing-section);
    }

    .vn-thanks-steps__h2 {
      font-size: var(--fs-h2);
      font-weight: 600;
      line-height: 1.2;
      color: var(--color-text-primary);
      text-align: center;
      margin-bottom: 48px;
      text-wrap: balance;
    }

    .vn-thanks-steps__grid {
      row-gap: 32px;
    }

    .vn-thanks-step {
      background-color: var(--color-bg-surface);
      border-radius: var(--radius-xl);
      border-top: 3px solid var(--color-accent-cta);
      padding: 28px;
      box-shadow: var(--shadow-card);
      transition: box-shadow 0.15s ease;
    }

    .vn-thanks-step:hover {
      box-shadow: var(--shadow-card-hover);
    }

    .vn-thanks-step__icon {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background-color: var(--color-accent-cta-soft);
      color: var(--color-accent-cta);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 16px;
    }

    .vn-thanks-step__num {
      display: block;
      font-size: var(--fs-caption);
      font-weight: 600;
      letter-spacing: 0.08em;
      color: var(--color-text-tertiary);
      margin-bottom: 8px;
    }

    .vn-thanks-step__title {
      font-size: var(--fs-h3);
      font-weight: 600;
      line-height: 1.25;
      color: var(--color-text-primary);
      margin-bottom: 10px;
      text-wrap: balance;
    }

    .vn-thanks-step__body {
      font-size: var(--fs-body);
      line-height: 1.65;
      color: var(--color-text-secondary);
      margin: 0;
      text-wrap: pretty;
    }

    /* ─── Block 4: Telegram ─── */
    .vn-thanks-telegram {
      background-color: var(--color-bg-primary);
      padding-block: var(--spacing-section);
      text-align: center;
    }

    .vn-thanks-telegram__icon {
      color: var(--color-accent-cta);
      margin-bottom: 20px;
    }

    .vn-thanks-telegram__h2 {
      font-size: var(--fs-h2);
      font-weight: 600;
      line-height: 1.2;
      color: var(--color-text-primary);
      margin-bottom: 16px;
      text-wrap: balance;
    }

    .vn-thanks-telegram__body {
      font-size: var(--fs-lead);
      line-height: 1.6;
      color: var(--color-text-secondary);
      max-width: 560px;
      margin: 0 auto 28px;
      text-wrap: pretty;
    }

    .vn-thanks-telegram__btn {
      margin-bottom: 12px;
    }

    .vn-thanks-telegram__micro {
      font-size: var(--fs-caption);
      color: var(--color-text-tertiary);
      margin: 0;
    }

    /* ─── Block 5: Nav Strip ─── */
    .vn-thanks-navstrip {
      background-color: var(--color-bg-dark);
      border-top: 1px solid var(--color-border-ondark);
    }

    .vn-thanks-navstrip__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      max-width: 1280px;
      margin-inline: auto;
      padding-inline: 48px;
      height: 60px;
      gap: 24px;
    }

    .vn-thanks-navstrip__logo {
      display: flex;
      align-items: center;
      flex-shrink: 0;
      color: var(--color-text-ondark);
      text-decoration: none;
    }

    .vn-thanks-navstrip__links {
      display: flex;
      align-items: center;
      gap: 0;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .vn-thanks-navstrip__links a {
      font-size: var(--fs-body-sm);
      color: var(--color-text-ondark);
      opacity: 0.5;
      text-decoration: none;
      padding: 4px 8px;
      transition: opacity 150ms ease;
      white-space: nowrap;
    }

    .vn-thanks-navstrip__links a:hover {
      opacity: 0.9;
    }

    .vn-thanks-navstrip__dot {
      font-size: var(--fs-body-sm);
      color: var(--color-text-ondark);
      opacity: 0.18;
      padding-inline: 2px;
      user-select: none;
    }

    /* ─── Animations ─── */
    @media (prefers-reduced-motion: no-preference) {
      .vn-thanks-checkmark__path {
        animation: vn-thanks-checkmark-draw 0.6s ease-out 0.3s forwards;
      }

      @keyframes vn-thanks-checkmark-draw {
        to { stroke-dashoffset: 0; }
      }

      .vn-thanks-checkmark__pulse {
        animation: vn-thanks-pulse 2s ease-in-out infinite;
      }

      @keyframes vn-thanks-pulse {
        0%, 100% { transform: scale(1); opacity: 0.6; }
        50% { transform: scale(1.15); opacity: 0; }
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .vn-thanks-checkmark__path {
        stroke-dashoffset: 0;
      }
    }

    /* ─── Mobile ─── */
    @media (max-width: 1023px) {
      .vn-thanks-confirm { padding-top: 80px; }
      .vn-thanks-video { padding-bottom: var(--spacing-section-mobile); }
      .vn-thanks-steps { padding-block: var(--spacing-section-mobile); }
      .vn-thanks-steps__grid > * { grid-column: 1 / -1 !important; }
      .vn-thanks-telegram { padding-block: var(--spacing-section-mobile); }
    }

    @media (max-width: 768px) {
      .vn-thanks-confirm { padding-top: 64px; padding-bottom: 48px; }
      .vn-thanks-navstrip__inner { padding-inline: 24px; }
      .vn-thanks-navstrip__links a { font-size: 12px; padding: 4px 6px; }
    }
  </style>
</BaseLayout>
