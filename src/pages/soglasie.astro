---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { COMPANY } from '@/lib/constants';
---

<BaseLayout title="Согласие на обработку персональных данных" noindex>
  <div class="site-container py-16 md:py-24">
    <article class="max-w-3xl mx-auto prose prose-lg">
      <h1 class="text-3xl md:text-4xl font-bold text-[var(--color-text-primary)]">
        Согласие на обработку персональных данных
      </h1>
      <p class="mt-6 text-[var(--color-text-secondary)]">
        Настоящим я даю согласие {COMPANY.legalName} (ИНН {COMPANY.inn}) на обработку моих персональных данных в соответствии с Федеральным законом от 27.07.2006 № 152-ФЗ «О персональных данных».
      </p>
      <!-- TODO: replace with legally verified consent text -->
    </article>
  </div>
</BaseLayout>
