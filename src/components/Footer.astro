---
import { COMPANY, SITE } from '@/lib/constants';
import { footerNavLinks } from '@/data/navigation';
---

<footer class="relative overflow-hidden bg-[var(--color-bg-deep)] text-[var(--color-text-ondark)]">
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(8,116,196,0.14),transparent_28%),radial-gradient(circle_at_bottom_right,rgba(91,199,242,0.08),transparent_24%)]"
    aria-hidden="true"
  />
  <div
    class="pointer-events-none absolute inset-x-0 top-0 h-px bg-[linear-gradient(90deg,transparent,rgba(91,199,242,0.28),transparent)]"
    aria-hidden="true"
  />

  <div class="site-container relative py-16 md:py-20">
    <div class="grid-12 gap-y-8 lg:gap-y-0">
      <div class="col-span-12 lg:col-span-4">
        <div class="rounded-[var(--radius-2xl)] border border-[var(--color-border-ondark)] bg-[rgba(255,255,255,0.03)] p-6 shadow-[0_24px_56px_-40px_rgba(0,0,0,0.45)] sm:p-7">
          <div class="flex items-center gap-3">
            <span class="inline-flex items-center rounded-full border border-[var(--color-border-ondark)] bg-[rgba(255,255,255,0.04)] px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.08em] text-[var(--color-accent-cyan)]">
              {SITE.shortName}
            </span>
          </div>

          <p class="mt-5 text-lg font-semibold leading-snug text-[var(--color-text-ondark)]">
            {SITE.name}
          </p>

          <div class="mt-6 space-y-3 text-sm text-[var(--color-text-ondark-mute)]">
            <p>{COMPANY.address}</p>
            <p>
              <a href={`tel:${COMPANY.officePhone.replace(/[()\s-]/g, '')}`} class="transition-colors hover:text-[var(--color-text-ondark)]">
                {COMPANY.officePhone}
              </a>
            </p>
            <p>
              <a href={`mailto:${COMPANY.email}`} class="transition-colors hover:text-[var(--color-text-ondark)]">
                {COMPANY.email}
              </a>
            </p>
          </div>
        </div>
      </div>

      <div class="col-span-12 lg:col-span-5 lg:px-4">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-ondark-soft)]">
          Навигация
        </p>

        <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2">
          {footerNavLinks.map((link) => (
            <a
              href={link.href}
              class="group flex items-start gap-3 rounded-[var(--radius-lg)] border border-[rgba(255,255,255,0.06)] bg-[rgba(255,255,255,0.02)] px-4 py-3 transition-all duration-200 hover:-translate-y-px hover:border-[rgba(91,199,242,0.2)] hover:bg-[rgba(255,255,255,0.04)]"
            >
              <span class="mt-0.5 text-[11px] font-semibold tracking-[0.08em] text-[var(--color-accent-cyan)]">
                {link.num}
              </span>
              <span class="text-sm leading-[1.45] text-[var(--color-text-ondark-mute)] transition-colors group-hover:text-[var(--color-text-ondark)]">
                {link.footerLabel}
              </span>
            </a>
          ))}
        </div>
      </div>

      <div class="col-span-12 lg:col-span-3">
        <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-ondark-soft)]">
          Контакты
        </p>

        <div class="mt-4 space-y-3">
          <a
            href={`tel:${COMPANY.officePhone.replace(/[()\s-]/g, '')}`}
            class="group flex items-center gap-3 rounded-[var(--radius-lg)] border border-[rgba(255,255,255,0.06)] bg-[rgba(255,255,255,0.02)] px-4 py-3 transition-all duration-200 hover:-translate-y-px hover:border-[rgba(91,199,242,0.2)] hover:bg-[rgba(255,255,255,0.04)]"
          >
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-[var(--radius-md)] bg-[rgba(91,199,242,0.08)] text-[var(--color-accent-cyan)]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 9.82 19.79 19.79 0 0 1 1.61 1.24 2 2 0 0 1 3.6 0h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 7.91a16 16 0 0 0 6.1 6.1l.88-.88a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.72 15.3" />
              </svg>
            </span>
            <span class="text-sm leading-snug text-[var(--color-text-ondark-mute)] transition-colors group-hover:text-[var(--color-text-ondark)]">
              {COMPANY.officePhone}
            </span>
          </a>

          <a
            href={`mailto:${COMPANY.email}`}
            class="group flex items-center gap-3 rounded-[var(--radius-lg)] border border-[rgba(255,255,255,0.06)] bg-[rgba(255,255,255,0.02)] px-4 py-3 transition-all duration-200 hover:-translate-y-px hover:border-[rgba(91,199,242,0.2)] hover:bg-[rgba(255,255,255,0.04)]"
          >
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-[var(--radius-md)] bg-[rgba(91,199,242,0.08)] text-[var(--color-accent-cyan)]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 4h16v16H4z" />
                <path d="m22 6-10 7L2 6" />
              </svg>
            </span>
            <span class="text-sm leading-snug text-[var(--color-text-ondark-mute)] transition-colors group-hover:text-[var(--color-text-ondark)]">
              {COMPANY.email}
            </span>
          </a>

          <div class="flex items-start gap-3 rounded-[var(--radius-lg)] border border-[rgba(255,255,255,0.06)] bg-[rgba(255,255,255,0.02)] px-4 py-3">
            <span class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-[var(--radius-md)] bg-[rgba(91,199,242,0.08)] text-[var(--color-accent-cyan)]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
                <circle cx="12" cy="10" r="3" />
              </svg>
            </span>
            <span class="text-sm leading-[1.5] text-[var(--color-text-ondark-mute)]">
              {COMPANY.address}
            </span>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-12 border-t border-[var(--color-border-ondark)] pt-8">
      <div class="flex flex-col gap-4 text-xs text-[var(--color-text-ondark-soft)] md:flex-row md:items-center md:justify-between">
        <p>
          © 2026 {SITE.name}. ИНН {COMPANY.inn}.
        </p>
        <div class="flex flex-wrap gap-x-5 gap-y-2">
          <a href="/politika/" class="transition-colors hover:text-[var(--color-text-ondark)]">Политика конфиденциальности</a>
          <a href="/cookies/" class="transition-colors hover:text-[var(--color-text-ondark)]">Политика использования cookies</a>
          <a href="/sitemap/" class="transition-colors hover:text-[var(--color-text-ondark)]">Карта сайта</a>
        </div>
      </div>
    </div>
  </div>
</footer>
