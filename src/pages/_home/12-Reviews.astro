---
const reviews = [
  {
    quote: 'Было много подводных камней и сложных вопросов',
    author: 'Илья Нем',
    date: '15 апреля 2025',
    context: 'Семейная ипотека и сложные вопросы',
  },
  {
    quote: 'Это была сделка, с которой не каждый специалист справится',
    author: 'Оксана Е.',
    date: '18 сентября 2025',
    context: 'Сделка со сложной ипотечной ситуацией',
  },
  {
    quote: 'Была с нами до самого завершения оформления ипотеки',
    author: 'Александр Бестужев',
    date: '26 января 2026',
    context: 'Подбор, документы и ипотека до завершения',
  },
];
---

<section id="section-reviews" class="bg-[var(--color-bg-surface)] vn-section-padding">
  <div class="site-container">
    <div class="max-w-2xl">
      <h2 class="text-3xl md:text-[42px] font-bold leading-tight text-[var(--color-text-primary)]">
        Отзывы о работе Ракурс как центра недвижимости
      </h2>
      <p class="mt-4 text-lg text-[var(--color-text-secondary)]">
        Отзывы подтверждают реальность компании и клиентского сервиса.
      </p>
    </div>

    <div class="mt-10 grid gap-5 md:grid-cols-3">
      {reviews.map((r) => (
        <div class="flex flex-col rounded-[var(--radius-lg)] bg-[var(--color-bg-primary)] p-6 border border-[var(--color-border)]">
          <svg class="text-[var(--color-accent-primary)]" width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
            <path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z"/>
          </svg>
          <p class="mt-4 text-base text-[var(--color-text-primary)] leading-relaxed flex-1">
            «{r.quote}»
          </p>
          <div class="mt-6 pt-4 border-t border-[var(--color-border)]">
            <p class="text-sm font-medium text-[var(--color-text-primary)]">{r.author}</p>
            <p class="text-xs text-[var(--color-text-tertiary)]">{r.context} · {r.date}</p>
          </div>
        </div>
      ))}
    </div>

    <p class="mt-6 text-xs text-[var(--color-text-tertiary)]">
      Источник: отзывы из Яндекс-карточки Центра недвижимости «Ракурс»
    </p>
  </div>
</section>
