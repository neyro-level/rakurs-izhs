---
const steps = [
  {
    num: '01',
    icon: 'send',
    title: 'Оставляете заявку',
    text: 'Указываете, на каком этапе вы сейчас: ищете участок, сравниваете сметы или нужна ипотека.',
    detail: 'Занимает 30 секунд',
  },
  {
    num: '02',
    icon: 'user',
    title: 'Артемий связывается с вами',
    text: 'Уточняет ситуацию: бюджет, ипотека, участок, сметы, подрядчики. Без давления и навязывания.',
    detail: 'В течение 2 часов',
  },
  {
    num: '03',
    icon: 'search',
    title: 'Разбираем ваш сценарий',
    text: 'Проверяем, что важно до договора: участок, подрядчик, смета, ипотека. Находим скрытые доплаты.',
    detail: '1-2 дня',
  },
  {
    num: '04',
    icon: 'check-circle',
    title: 'Получаете понятный план',
    text: 'Знаете следующий шаг: ипотека, участок, смета, подрядчик или договор. Без хаоса и неопределённости.',
    detail: 'Результат разбора',
  },
];
---

<section
  id="section-path"
  data-review-id="home-path"
  data-review-title="Главная: как проходит разбор"
  data-review-path="src/pages/_home/08-Path.astro"
  class="relative overflow-hidden bg-[var(--color-bg-surface)] vn-section-padding"
>
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(8,116,196,0.08),transparent_28%),radial-gradient(circle_at_bottom_right,rgba(91,199,242,0.08),transparent_26%)]"
    aria-hidden="true"
  />

  <div class="site-container relative">
    <div class="grid-12 items-start gap-y-8 lg:gap-y-0">
      <div class="col-span-12 lg:col-span-4">
        <div class="rounded-[var(--radius-2xl)] border border-[var(--color-border)] bg-[var(--color-bg-primary)] p-6 sm:p-8 lg:sticky lg:top-24 shadow-[0_24px_60px_-36px_rgba(7,27,58,0.16)]">
          <span class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.06em] text-[var(--color-accent-primary)]">
            <span class="block h-px w-6 bg-[var(--color-accent-primary)]" />
            Как мы работаем
          </span>

          <h2 class="mt-5 text-[28px] font-bold leading-[1.14] tracking-[-0.01em] text-[var(--color-text-primary)] md:text-[36px] lg:text-[40px]">
            Путь от заявки до понятного решения:
            <span class="text-[var(--color-accent-primary)]"> 4 шага</span> с Артемием Никулиным
          </h2>

          <p class="mt-4 max-w-[34ch] text-base leading-relaxed text-[var(--color-text-secondary)] md:text-lg">
            Без хаоса и неопределённости. Вы всегда знаете, что происходит и что будет дальше.
          </p>

          <div class="mt-8">
            <button
              type="button"
              data-open-modal
              data-scenario="dont_know"
              class="inline-flex min-h-[48px] w-full items-center justify-center rounded-[var(--radius-md)] bg-[var(--color-accent-primary)] px-7 py-4 text-base font-semibold text-white transition-all duration-200 hover:-translate-y-px hover:bg-[var(--color-accent-hover)] shadow-[0_12px_24px_-12px_rgba(8,116,196,0.52)] sm:w-auto"
            >
              Получить разбор строительства
            </button>
          </div>

          <p class="mt-4 max-w-[30ch] text-sm leading-relaxed text-[var(--color-text-tertiary)]">
            После заявки вы получаете понятный план действий. Без обязательств и давления.
          </p>
        </div>
      </div>

      <div class="col-span-12 lg:col-span-8 lg:pl-8">
        <div class="relative grid grid-cols-1 gap-5 md:grid-cols-2 md:gap-6">
          <div
            class="pointer-events-none absolute left-1/2 top-[26%] hidden h-px w-[calc(100%-8rem)] -translate-x-1/2 bg-[linear-gradient(90deg,rgba(8,116,196,0.08),rgba(8,116,196,0.22),rgba(8,116,196,0.08))] md:block"
            aria-hidden="true"
          />
          <div
            class="pointer-events-none absolute left-1/2 top-[26%] hidden h-[48%] w-px -translate-x-1/2 bg-[linear-gradient(180deg,rgba(8,116,196,0.08),rgba(8,116,196,0.22),rgba(8,116,196,0.08))] md:block"
            aria-hidden="true"
          />

          {steps.map((step) => (
            <article class="group relative flex h-full flex-col overflow-hidden rounded-[var(--radius-2xl)] border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-6 shadow-[0_18px_48px_-36px_rgba(7,27,58,0.2)] transition-all duration-200 hover:-translate-y-1 hover:border-[var(--color-border-strong)] hover:shadow-[0_26px_56px_-32px_rgba(7,27,58,0.24)] sm:p-7">
              <div
                class="pointer-events-none absolute inset-x-0 top-0 h-px bg-[linear-gradient(90deg,transparent,rgba(8,116,196,0.3),transparent)]"
                aria-hidden="true"
              />

              <div class="flex items-start justify-between gap-4">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-[var(--radius-md)] bg-[var(--color-accent-soft)] text-[var(--color-accent-primary)]">
                  {step.icon === 'send' && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <line x1="22" y1="2" x2="11" y2="13" />
                      <polygon points="22 2 15 22 11 13 2 9 22 2" />
                    </svg>
                  )}
                  {step.icon === 'user' && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                      <circle cx="12" cy="7" r="4" />
                    </svg>
                  )}
                  {step.icon === 'search' && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <circle cx="11" cy="11" r="8" />
                      <line x1="21" y1="21" x2="16.65" y2="16.65" />
                    </svg>
                  )}
                  {step.icon === 'check-circle' && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                      <polyline points="22 4 12 14.01 9 11.01" />
                    </svg>
                  )}
                </div>

                <span class="text-[32px] font-bold leading-none tracking-[-0.03em] text-[color-mix(in_srgb,var(--color-accent-primary)_22%,white)]">
                  {step.num}
                </span>
              </div>

              <h3 class="mt-6 text-lg font-semibold leading-snug text-[var(--color-text-primary)] md:text-xl">
                {step.title}
              </h3>

              <p class="mt-3 text-sm leading-[1.65] text-[var(--color-text-secondary)] md:text-base">
                {step.text}
              </p>

              <div class="mt-5 pt-5 border-t border-[var(--color-border)]">
                <span class="inline-flex items-center gap-2 text-xs font-semibold text-[var(--color-accent-primary)]">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="10" />
                    <polyline points="12 6 12 12 16 14" />
                  </svg>
                  {step.detail}
                </span>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
