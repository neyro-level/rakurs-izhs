---
import PageLayout from '@/layouts/PageLayout.astro';
import { SITE } from '@/lib/constants';
import { breadcrumbSchema } from '@/lib/seo';
import CookieToggle from '@/components/shared/CookieToggle';

const tocItems = [
  { num: '1', label: 'Общие положения', href: '#section-1' },
  { num: '2', label: 'Что такое cookie', href: '#section-2' },
  { num: '3', label: 'Какие cookie используются', href: '#section-3' },
  { num: '4', label: 'Цели использования', href: '#section-4' },
  { num: '5', label: 'Сторонние сервисы', href: '#section-5' },
  { num: '6', label: 'Яндекс.Метрика', href: '#section-6' },
  { num: '7', label: 'Управление cookie', href: '#section-7' },
  { num: '8', label: 'Последствия отключения', href: '#section-8' },
  { num: '9', label: 'Согласие на использование', href: '#section-9' },
  { num: '10', label: 'Отзыв согласия', href: '#section-10' },
  { num: '11', label: 'Обновление Правил', href: '#section-11' },
  { num: '12', label: 'Связь с Политикой ПД', href: '#section-12' },
];
---

<PageLayout
  title="Правила использования Cookie — Ракурс ИЖС"
  description="Правила использования файлов cookie на сайте Центра недвижимости «Ракурс». Категории cookie, управление согласием, настройки браузеров."
  canonical={`${SITE.url}/cookies/`}
  schema={breadcrumbSchema([
    { name: 'Главная', url: `${SITE.url}/` },
    { name: 'Правила использования Cookie', url: `${SITE.url}/cookies/` },
  ])}
>
  {/* A. Document Cover */}
  <section class="vn-section vn-section--dark vn-cookies-cover">
    <div class="vn-deco-grid vn-deco-grid--dark" aria-hidden="true"></div>
    <div class="vn-container">
      <div class="vn-grid-12" style="align-items: center;">
        <div class="vn-cookies-cover__left" style="grid-column: 1 / 8;">
          <span class="vn-label-mono vn-cookies-cover__label">Правила использования cookie</span>
          <h1 class="vn-cookies-cover__h1">Правила использования файлов&nbsp;cookie</h1>
        </div>
        <div class="vn-cookies-cover__right" style="grid-column: 8 / 13;">
          <span class="vn-cookies-cover__badge">Дата: 12&nbsp;мая&nbsp;2026&nbsp;г.</span>
          <a href="/privacy/" class="vn-cookies-cover__link">
            Политика конфиденциальности
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* B. Table of Contents */}
  <section class="vn-section vn-section--secondary vn-cookies-toc">
    <div class="vn-container">
      <div class="vn-grid-12">
        <div class="vn-cookies-toc__grid" style="grid-column: 1 / -1;">
          {tocItems.map(item => (
            <a href={item.href} class="vn-cookies-toc__link">
              <span class="vn-cookies-toc__dot" aria-hidden="true"></span>
              <span class="vn-cookies-toc__num">{item.num}.</span>
              <span class="vn-cookies-toc__label">{item.label}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* C. Cookie-type Cards */}
  <section class="vn-section vn-cookies-types">
    <div class="vn-container">
      <div class="vn-grid-12 vn-cookies-types__grid">
        {/* Card 1 — Технические */}
        <div class="vn-cookies-type vn-cookies-type--ok">
          <span class="vn-cookies-type__badge vn-cookies-type__badge--ok">Обязательные</span>
          <h3 class="vn-cookies-type__title">Технические cookie</h3>
          <p class="vn-cookies-type__body">Обеспечивают работу сайта. Срок: до&nbsp;24&nbsp;часов.</p>
          <div class="vn-cookies-type__status">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="vn-cookies-type__icon-ok"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <span>Всегда включены</span>
          </div>
        </div>

        {/* Card 2 — Функциональные */}
        <div class="vn-cookies-type vn-cookies-type--ok">
          <span class="vn-cookies-type__badge vn-cookies-type__badge--ok">Обязательные</span>
          <h3 class="vn-cookies-type__title">Функциональные cookie</h3>
          <p class="vn-cookies-type__body">Запоминают настройки пользователя. Срок: до&nbsp;12&nbsp;месяцев.</p>
          <div class="vn-cookies-type__status">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="vn-cookies-type__icon-ok"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <span>Всегда включены</span>
          </div>
        </div>

        {/* Card 3 — Аналитические */}
        <div class="vn-cookies-type" style="--cookie-border: var(--color-accent-cta);">
          <span class="vn-cookies-type__badge" style="background: var(--color-accent-cta-soft); color: var(--color-accent-cta);">По вашему выбору</span>
          <h3 class="vn-cookies-type__title">Аналитические cookie</h3>
          <p class="vn-cookies-type__body">Анализ посещаемости через Яндекс.Метрику. Срок: до&nbsp;24&nbsp;месяцев.</p>
          <div class="vn-cookies-type__status">
            <CookieToggle client:load />
          </div>
        </div>

        {/* Card 4 — Рекламные */}
        <div class="vn-cookies-type" style="--cookie-border: var(--color-border);">
          <span class="vn-cookies-type__badge" style="background: var(--color-bg-secondary); color: var(--color-text-tertiary);">Не используются</span>
          <h3 class="vn-cookies-type__title" style="color: var(--color-text-secondary);">Рекламные и маркетинговые</h3>
          <p class="vn-cookies-type__body">На данном сайте не используются.</p>
          <div class="vn-cookies-type__status">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="color: var(--color-text-tertiary);"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>
            <span>Отключены</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* D. Sections 1–12 */}
  <section class="vn-section vn-cookies-sections">
    <div class="vn-container" style="max-width: 900px;">
      <div class="vn-cookies-sections__stack">

        {/* Section 1 */}
        <article class="vn-cookies-section" id="section-1">
          <span class="vn-cookies-section__num" aria-hidden="true">01</span>
          <div class="vn-cookies-section__content">
            <span class="vn-cookies-section__badge">§ 1</span>
            <h2 class="vn-cookies-section__h2">Общие положения</h2>
            <div class="vn-cookies-section__body">
              <p>Настоящие Правила использования файлов cookie определяют порядок применения файлов cookie и аналогичных технологий на сайте.</p>
              <p>Файлы cookie используются для корректной работы сайта, анализа его посещаемости, улучшения пользовательского опыта, сохранения отдельных пользовательских настроек, а также для оценки эффективности рекламных и информационных материалов.</p>
              <p>Оператор персональных данных, порядок обработки персональных данных, права пользователей и способы связи с Оператором указаны в Политике обработки персональных данных, размещённой по адресу: /politika.</p>
              <p>Используя сайт, пользователь подтверждает, что ознакомился с настоящими Правилами и Политикой обработки персональных данных.</p>
            </div>
          </div>
        </article>

        {/* Section 2 */}
        <article class="vn-cookies-section" id="section-2">
          <span class="vn-cookies-section__num" aria-hidden="true">02</span>
          <div class="vn-cookies-section__content">
            <span class="vn-cookies-section__badge">§ 2</span>
            <h2 class="vn-cookies-section__h2">Что такое cookie</h2>
            <div class="vn-cookies-section__body">
              <p>Cookie — это небольшие текстовые файлы, которые сохраняются на устройстве пользователя при посещении сайта.</p>
              <p>Cookie могут содержать техническую информацию о браузере, устройстве, действиях пользователя на сайте, выбранных настройках, источнике перехода и других параметрах взаимодействия с сайтом.</p>
              <p>Cookie сами по себе не запускают программы, не получают доступ к файлам устройства пользователя и не позволяют идентифицировать пользователя без связи с другой информацией. При этом отдельные cookie и данные аналитических сервисов могут относиться к персональным данным, если позволяют прямо или косвенно определить пользователя или его устройство.</p>
            </div>
          </div>
        </article>

        {/* Section 3 */}
        <article class="vn-cookies-section" id="section-3">
          <span class="vn-cookies-section__num" aria-hidden="true">03</span>
          <div class="vn-cookies-section__content">
            <span class="vn-cookies-section__badge">§ 3</span>
            <h2 class="vn-cookies-section__h2">Какие cookie могут использоваться на сайте</h2>
            <div class="vn-cookies-section__body">
              <p>На сайте могут использоваться следующие категории cookie.</p>
              <div class="vn-cookies-table" role="table" aria-label="Категории cookie">
                <div class="vn-cookies-table__row vn-cookies-table__row--head" role="row">
                  <div role="columnheader">Категория cookie</div>
                  <div role="columnheader">Для чего используются</div>
                  <div role="columnheader">Примерный срок хранения</div>
                </div>
                <div class="vn-cookies-table__row" role="row">
                  <div role="cell"><strong>Технические cookie</strong></div>
                  <div role="cell">Обеспечивают работу сайта, навигацию, безопасность, корректное отображение страниц и форм</div>
                  <div role="cell">До закрытия браузера или до 24&nbsp;часов</div>
                </div>
                <div class="vn-cookies-table__row" role="row">
                  <div role="cell"><strong>Функциональные cookie</strong></div>
                  <div role="cell">Запоминают выбранные настройки пользователя, например регион, язык, параметры отображения или ранее введённые данные</div>
                  <div role="cell">До 12&nbsp;месяцев</div>
                </div>
                <div class="vn-cookies-table__row" role="row">
                  <div role="cell"><strong>Аналитические cookie</strong></div>
                  <div role="cell">Помогают анализировать посещаемость сайта, популярные страницы, источники переходов, устройства, браузеры и поведение пользователей</div>
                  <div role="cell">До 24&nbsp;месяцев</div>
                </div>
                <div class="vn-cookies-table__row" role="row">
                  <div role="cell"><strong>Рекламные и маркетинговые cookie</strong></div>
                  <div role="cell">Используются для оценки эффективности рекламы, настройки рекламных аудиторий, ретаргетинга и ограничения показа нерелевантных объявлений</div>
                  <div role="cell">До 24&nbsp;месяцев</div>
                </div>
              </div>
              <p>Фактический состав cookie зависит от настроек сайта, подключённых сервисов аналитики, рекламных систем, виджетов, форм, мессенджеров и иных технических инструментов.</p>
            </div>
          </div>
        </article>

        {/* Section 4 */}
        <article class="vn-cookies-section" id="section-4">
          <span class="vn-cookies-section__num" aria-hidden="true">04</span>
          <div class="vn-cookies-section__content">
            <span class="vn-cookies-section__badge">§ 4</span>
            <h2 class="vn-cookies-section__h2">Цели использования cookie</h2>
            <div class="vn-cookies-section__body">
              <p>Сайт может использовать cookie для следующих целей:</p>
              <p><strong>4.1. Обеспечение работы сайта:</strong></p>
              <ul class="vn-cookies-list">
                <li>корректная загрузка страниц;</li>
                <li>работа навигации, форм, всплывающих окон и интерактивных элементов;</li>
                <li>сохранение технической сессии пользователя;</li>
                <li>защита сайта от некорректных или автоматизированных действий;</li>
                <li>предотвращение технических ошибок.</li>
              </ul>
              <p><strong>4.2. Анализ посещаемости:</strong></p>
              <ul class="vn-cookies-list">
                <li>подсчёт количества посетителей;</li>
                <li>анализ источников переходов на сайт;</li>
                <li>определение популярных страниц и разделов;</li>
                <li>оценка глубины просмотра и времени нахождения на сайте;</li>
                <li>выявление технических проблем и улучшение структуры сайта.</li>
              </ul>
              <p><strong>4.3. Улучшение пользовательского опыта:</strong></p>
              <ul class="vn-cookies-list">
                <li>сохранение отдельных предпочтений пользователя;</li>
                <li>упрощение повторного взаимодействия с сайтом;</li>
                <li>адаптация интерфейса под устройство и браузер пользователя;</li>
                <li>улучшение качества контента, навигации и форм.</li>
              </ul>
              <p><strong>4.4. Реклама и маркетинг:</strong></p>
              <ul class="vn-cookies-list">
                <li>оценка эффективности рекламных кампаний;</li>
                <li>анализ действий пользователей после перехода с рекламы;</li>
                <li>формирование и настройка рекламных аудиторий;</li>
                <li>ретаргетинг;</li>
                <li>исключение показа нерелевантной рекламы;</li>
                <li>улучшение рекламных сообщений и посадочных страниц.</li>
              </ul>
            </div>
          </div>
        </article>

        {/* Section 5 */}
        <article class="vn-cookies-section" id="section-5">
          <span class="vn-cookies-section__num" aria-hidden="true">05</span>
          <div class="vn-cookies-section__content">
            <span class="vn-cookies-section__badge">§ 5</span>
            <h2 class="vn-cookies-section__h2">Сторонние сервисы</h2>
            <div class="vn-cookies-section__body">
              <p>На сайте могут использоваться сторонние сервисы аналитики, рекламы, коммуникации, карт, видеоплееров, форм, мессенджеров и иных технических инструментов.</p>
              <p>Такие сервисы могут устанавливать собственные cookie или получать технические данные о взаимодействии пользователя с сайтом.</p>
              <p>К таким сервисам могут относиться:</p>
              <ul class="vn-cookies-list">
                <li>Яндекс.Метрика;</li>
                <li>Яндекс.Директ;</li>
                <li>VK Реклама;</li>
                <li>Telegram Ads;</li>
                <li>сервисы обратной связи и онлайн-чата;</li>
                <li>сервисы карт и навигации;</li>
                <li>иные сервисы, подключённые к сайту.</li>
              </ul>
              <p>Использование сторонних сервисов осуществляется в соответствии с их правилами и политиками конфиденциальности. Подробная информация об обработке персональных данных на сайте указывается в Политике обработки персональных данных по адресу: /politika.</p>
            </div>
          </div>
        </article>

        {/* Section 6 */}
        <article class="vn-cookies-section" id="section-6">
          <span class="vn-cookies-section__num" aria-hidden="true">06</span>
          <div class="vn-cookies-section__content">
            <span class="vn-cookies-section__badge">§ 6</span>
            <h2 class="vn-cookies-section__h2">Яндекс.Метрика и аналитические данные</h2>
            <div class="vn-cookies-section__body">
              <p>На сайте может использоваться сервис веб-аналитики Яндекс.Метрика.</p>
              <p>Яндекс.Метрика может собирать техническую и статистическую информацию о посещениях сайта, включая сведения о страницах, действиях пользователя, источнике перехода, устройстве, браузере, приблизительной географии и иных параметрах взаимодействия с сайтом.</p>
              <p>Эти данные используются для анализа работы сайта, улучшения его структуры, содержания, скорости загрузки, удобства навигации и качества рекламных кампаний.</p>
              <p>Пользователь может ограничить сбор данных Яндекс.Метрикой с помощью настроек браузера или специальных инструментов, предоставляемых Яндексом.</p>
            </div>
          </div>
        </article>

        {/* Section 7 */}
        <article class="vn-cookies-section" id="section-7">
          <span class="vn-cookies-section__num" aria-hidden="true">07</span>
          <div class="vn-cookies-section__content">
            <span class="vn-cookies-section__badge">§ 7</span>
            <h2 class="vn-cookies-section__h2">Управление cookie</h2>
            <div class="vn-cookies-section__body">
              <p>Пользователь может самостоятельно управлять файлами cookie через настройки своего браузера.</p>
              <p>Обычно браузер позволяет:</p>
              <ul class="vn-cookies-list">
                <li>удалить ранее сохранённые cookie;</li>
                <li>заблокировать cookie для всех сайтов;</li>
                <li>заблокировать cookie для отдельных сайтов;</li>
                <li>ограничить сторонние cookie;</li>
                <li>настроить уведомления перед сохранением cookie;</li>
                <li>очистить данные сайтов после закрытия браузера.</li>
              </ul>
              <p>Порядок управления cookie зависит от используемого браузера:</p>
              <div class="vn-cookies-table vn-cookies-table--browsers" role="table" aria-label="Настройки cookie в браузерах">
                <div class="vn-cookies-table__row vn-cookies-table__row--head" role="row">
                  <div role="columnheader">Браузер</div>
                  <div role="columnheader">Где искать настройки</div>
                </div>
                <div class="vn-cookies-table__row" role="row">
                  <div role="cell"><strong>Google Chrome</strong></div>
                  <div role="cell">Настройки → Конфиденциальность и безопасность → Файлы cookie и другие данные сайтов</div>
                </div>
                <div class="vn-cookies-table__row" role="row">
                  <div role="cell"><strong>Яндекс Браузер</strong></div>
                  <div role="cell">Настройки → Сайты → Расширенные настройки сайтов → Cookie-файлы</div>
                </div>
                <div class="vn-cookies-table__row" role="row">
                  <div role="cell"><strong>Mozilla Firefox</strong></div>
                  <div role="cell">Настройки → Приватность и защита → Куки и данные сайтов</div>
                </div>
                <div class="vn-cookies-table__row" role="row">
                  <div role="cell"><strong>Safari</strong></div>
                  <div role="cell">Настройки → Конфиденциальность → Управление данными сайтов</div>
                </div>
                <div class="vn-cookies-table__row" role="row">
                  <div role="cell"><strong>Microsoft Edge</strong></div>
                  <div role="cell">Настройки → Файлы cookie и разрешения сайтов</div>
                </div>
              </div>
            </div>
          </div>
        </article>

        {/* Section 8 */}
        <article class="vn-cookies-section" id="section-8">
          <span class="vn-cookies-section__num" aria-hidden="true">08</span>
          <div class="vn-cookies-section__content">
            <span class="vn-cookies-section__badge">§ 8</span>
            <h2 class="vn-cookies-section__h2">Последствия отключения cookie</h2>
            <div class="vn-cookies-section__body">
              <p>Если пользователь отключит или ограничит использование cookie, отдельные функции сайта могут работать некорректно.</p>
              <p>Возможные последствия:</p>
              <ul class="vn-cookies-list">
                <li>некоторые страницы могут отображаться неправильно;</li>
                <li>формы, всплывающие окна или интерактивные элементы могут работать с ограничениями;</li>
                <li>сайт может не запомнить выбранные настройки;</li>
                <li>пользователю может потребоваться повторно вводить данные;</li>
                <li>аналитика посещений будет менее точной;</li>
                <li>рекламные материалы могут стать менее релевантными.</li>
              </ul>
              <p>Технические cookie необходимы для базовой работы сайта. Ограничение технических cookie может привести к невозможности корректного использования отдельных функций сайта.</p>
            </div>
          </div>
        </article>

        {/* Section 9 */}
