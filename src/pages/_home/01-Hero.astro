---
import { EXPERT } from '@/lib/constants';

const checks = [
  { label: 'Бюджет и ипотека', status: 'проверяем' },
  { label: 'Участок', status: 'сравниваем' },
  { label: 'Подрядчик', status: 'уточняем' },
  { label: 'Смета', status: 'проверяем' },
  { label: 'Возможные доплаты', status: 'сравниваем' },
];

const trusts = [
  'Проверяем ипотечный сценарий',
  'Сравниваем сметы до договора',
  'Помогаем с участком и подрядчиком',
  'Для клиента без отдельной оплаты',
  `Ответственный эксперт — ${EXPERT.name}`,
];
---

<section id="section-hero" class="relative bg-[var(--color-bg-dark)] text-[var(--color-text-ondark)] overflow-hidden">
  <!-- Decorative grid + gradient -->
  <div class="absolute inset-0 opacity-30"
    style="background-image: radial-gradient(circle at 20% 10%, rgba(91,199,242,0.22) 0%, rgba(91,199,242,0.08) 32%, transparent 68%);"
  />
  <div class="absolute inset-0"
    style="background-image: linear-gradient(rgba(255,255,255,0.045) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.045) 1px, transparent 1px); background-size: 64px 64px;"
  />

  <div class="site-container relative vn-section-padding-lg">
    <div class="grid-12 items-center">
      <!-- Left: 7 cols -->
      <div class="col-span-12 lg:col-span-7 flex flex-col gap-6">
        <span class="inline-flex items-center gap-2 self-start rounded-[var(--radius-sm)] bg-[rgba(255,255,255,0.08)] border border-[rgba(255,255,255,0.14)] px-3 py-1.5 text-xs font-medium uppercase tracking-wider text-[var(--color-text-ondark)]">
          <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-accent-cyan)]" />
          Ракурс ИЖС — Пермь
        </span>

        <h1 class="text-4xl md:text-5xl lg:text-[56px] font-extrabold leading-[1.08] tracking-[-0.02em]">
          Построить дом в Перми <span class="text-[var(--color-accent-cyan)]">без ошибки</span> в участке, подрядчике и смете
        </h1>

        <p class="text-lg md:text-xl text-[var(--color-text-ondark-mute)] max-w-2xl leading-relaxed">
          Помогаем понять, какой дом можно построить по вашему бюджету: подбираем участок, проверяем подрядчика, сравниваем смету и показываем расходы до договора.
        </p>

        <div class="flex flex-wrap gap-4 mt-2">
          <button
            type="button"
            data-open-modal
            class="inline-flex items-center justify-center rounded-[var(--radius-md)] bg-white text-[var(--color-bg-dark)] px-7 py-4 text-base font-medium hover:bg-[var(--color-bg-secondary)] transition-colors"
          >
            Понять, с чего начать
          </button>
          <button
            type="button"
            data-open-modal
            data-scenario="estimate"
            class="inline-flex items-center justify-center rounded-[var(--radius-md)] border border-[var(--color-border-ondark)] text-[var(--color-text-ondark)] px-7 py-4 text-base font-medium hover:bg-white/5 transition-colors"
          >
            Уже есть смета
          </button>
        </div>

        <div class="mt-4 flex flex-wrap gap-x-6 gap-y-2">
          {trusts.map((t) => (
            <span class="flex items-center gap-2 text-sm text-[var(--color-text-ondark-soft)]">
              <svg class="shrink-0 text-[var(--color-accent-cyan)]" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12" />
              </svg>
              {t}
            </span>
          ))}
        </div>
      </div>

      <!-- Right: 5 cols — Scenario Panel -->
      <div class="col-span-12 lg:col-span-5 mt-10 lg:mt-0">
        <div class="rounded-[var(--radius-xl)] bg-[var(--color-bg-dark-elev)] border border-[var(--color-border-ondark)] p-6 md:p-8">
          <h2 class="text-lg font-semibold text-[var(--color-text-ondark)]">
            Что проверим до договора
          </h2>
          <p class="mt-1 text-sm text-[var(--color-text-ondark-soft)]">
            Ракурс не строит сам, а помогает проверить сценарий
          </p>

          <div class="mt-6 space-y-3">
            {checks.map((c) => (
              <div class="flex items-center justify-between gap-4 rounded-[var(--radius-md)] bg-[rgba(255,255,255,0.04)] px-4 py-3">
                <span class="text-sm text-[var(--color-text-ondark)]">{c.label}</span>
                <span class="shrink-0 rounded-[var(--radius-sm)] bg-[var(--color-accent-soft)] px-2 py-1 text-xs font-semibold uppercase tracking-wider text-[var(--color-accent-primary)]">
                  {c.status}
                </span>
              </div>
            ))}
          </div>

          <button
            type="button"
            data-open-modal
            class="mt-6 w-full inline-flex items-center justify-center rounded-[var(--radius-md)] bg-[var(--color-accent-primary)] text-white px-5 py-3 text-sm font-medium hover:bg-[var(--color-accent-hover)] transition-colors"
          >
            Получить разбор
          </button>
        </div>
      </div>
    </div>
  </div>
</section>
