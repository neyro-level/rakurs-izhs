---
import ProjectSlider from './ProjectSlider';

interface ProjectSlide {
  alt: string;
  src?: string;
  type: 'photo' | 'plan';
}

interface ProjectCard {
  id: string;
  name: string;
  area: string;
  budget: string;
  featured: boolean;
  images: ProjectSlide[];
  includes: string[];
  separate: string[];
}

const projects: ProjectCard[] = [
  {
    id: 'compact',
    name: 'Компактный',
    area: '80 м²',
    budget: 'от 6 млн',
    featured: false,
    images: [
      { alt: 'Фасад дома', type: 'photo' },
      { alt: 'Вид сбоку', type: 'photo' },
      { alt: 'Вид сзади', type: 'photo' },
      { alt: 'Планировка', type: 'plan' },
    ],
    includes: [
      'Фундамент и коробка',
      'Кровля и окна',
      'Черновая отделка',
      'Инженерия (электрика, отопление)',
    ],
    separate: [
      'Участок',
      'Чистовая отделка',
      'Ландшафт',
    ],
  },
  {
    id: 'family',
    name: 'Семейный',
    area: '95 м²',
    budget: 'от 7 млн',
    featured: true,
    images: [
      { alt: 'Фасад дома', type: 'photo' },
      { alt: 'Вид сбоку', type: 'photo' },
      { alt: 'Вид сзади', type: 'photo' },
      { alt: 'Планировка', type: 'plan' },
    ],
    includes: [
      'Фундамент и коробка',
      'Кровля и окна',
      'Черновая отделка',
      'Инженерия (электрика, отопление, вода)',
      'Предчистовая отделка',
    ],
    separate: [
      'Участок',
      'Чистовая отделка',
    ],
  },
  {
    id: 'spacious',
    name: 'Просторный',
    area: '120 м²',
    budget: 'от 8,5 млн',
    featured: false,
    images: [
      { alt: 'Фасад дома', type: 'photo' },
      { alt: 'Вид сбоку', type: 'photo' },
      { alt: 'Вид сзади', type: 'photo' },
      { alt: 'Планировка', type: 'plan' },
    ],
    includes: [
      'Фундамент и коробка',
      'Кровля и окна',
      'Черновая отделка',
      'Инженерия (полный комплект)',
      'Предчистовая отделка',
      'Терраса',
    ],
    separate: [
      'Участок',
      'Чистовая отделка',
    ],
  },
];
---

<section
  id="section-projects"
  data-review-id="home-projects"
  data-review-title="Главная: проекты домов"
  data-review-path="src/pages/_home/03-Projects.astro"
  class="bg-[var(--color-bg-surface)] vn-section-padding"
>
  <div class="site-container">
    
    <!-- Header -->
    <div class="fade-in-up max-w-3xl">
      <span class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.06em] text-[var(--color-accent-primary)]">
        <span class="block w-6 h-px bg-[var(--color-accent-primary)]" />
        Проекты домов
      </span>

      <h2 class="mt-5 text-[28px] md:text-[36px] lg:text-[42px] font-bold leading-[1.14] tracking-[-0.01em] text-[var(--color-text-primary)]">
        Какой дом реально построить<br class="hidden md:block" />
        под ваш бюджет и ипотеку 6%
      </h2>

      <p class="mt-4 text-base md:text-lg text-[var(--color-text-secondary)] leading-relaxed max-w-[58ch]">
        Три типовых проекта с разбивкой по составу работ. Точная цена зависит от участка, подрядчика и комплектации — считаем на разборе.
      </p>
    </div>

    <!-- Projects grid -->
    <div class="mt-12 md:mt-16 grid auto-cols-[minmax(280px,88%)] grid-flow-col gap-5 overflow-x-auto pb-2 pr-5 snap-x snap-mandatory [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden sm:auto-cols-auto sm:grid-flow-row sm:grid-cols-2 sm:overflow-visible sm:pb-0 sm:pr-0 lg:grid-cols-3">
      {projects.map((p) => (
        <article class={`fade-in-up flex h-full snap-start flex-col overflow-hidden rounded-[var(--radius-2xl)] border transition-all duration-300 ${
          p.featured
            ? 'bg-[var(--color-bg-dark)] border-[var(--color-accent-primary)] shadow-[0_22px_50px_-28px_rgba(8,116,196,0.42)]'
            : 'bg-[var(--color-bg-surface)] border-[var(--color-border)] shadow-[0_18px_40px_-32px_rgba(7,27,58,0.16)] hover:-translate-y-0.5 hover:border-[var(--color-border-strong)] hover:shadow-[0_22px_44px_-28px_rgba(7,27,58,0.22)]'
        }`}>
          <ProjectSlider client:visible slides={p.images} projectName={p.name} />

          {/* Content */}
          <div class="flex flex-1 flex-col p-5 md:p-6">
            <div class="flex items-start justify-between gap-3">
              <div>
                <h3 class={`text-[26px] font-bold leading-[1.12] tracking-[-0.01em] ${p.featured ? 'text-[var(--color-text-ondark)]' : 'text-[var(--color-text-primary)]'}`}>
                  {p.name}
                </h3>
              </div>

              <div class={`inline-flex rounded-[var(--radius-pill)] px-3 py-1 text-sm font-medium ${
                p.featured
                  ? 'bg-[rgba(255,255,255,0.08)] text-[var(--color-text-ondark)] border border-[var(--color-border-ondark)]'
                  : 'bg-[var(--color-accent-soft)] text-[var(--color-accent-primary)]'
              }`}>
                {p.area}
              </div>
            </div>

            <div class={`mt-5 rounded-[var(--radius-xl)] border p-4 ${
              p.featured
                ? 'border-[var(--color-border-ondark)] bg-[rgba(255,255,255,0.06)]'
                : 'border-[var(--color-border)] bg-[var(--color-bg-surface-low)]'
            }`}>
              <div class="flex items-end justify-between gap-3">
                <span class={`text-[34px] font-extrabold leading-none ${
                  p.featured ? 'text-[var(--color-accent-cyan)]' : 'text-[var(--color-accent-primary)]'
                }`}>
                  {p.budget}
                </span>
              </div>
            </div>

            <div class="mt-5 grid gap-3">
              <div class={`rounded-[var(--radius-xl)] border p-4 ${
                p.featured
                  ? 'border-[var(--color-border-ondark)] bg-[rgba(255,255,255,0.04)]'
                  : 'border-[var(--color-border)] bg-[var(--color-bg-surface)]'
              }`}>
                <p class={`text-xs font-semibold uppercase tracking-[0.06em] ${
                  p.featured ? 'text-[var(--color-accent-cyan)]' : 'text-[var(--color-accent-primary)]'
                }`}>
                  Что входит
                </p>
                <ul class="mt-3 space-y-2.5">
                  {p.includes.map((item) => (
                    <li class="flex items-start gap-2.5">
                      <svg class={`mt-0.5 shrink-0 ${p.featured ? 'text-[var(--color-accent-cyan)]' : 'text-[var(--color-accent-primary)]'}`} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polyline points="20 6 9 17 4 12" />
                      </svg>
                      <span class={`text-sm leading-[1.5] ${p.featured ? 'text-[var(--color-text-ondark)]' : 'text-[var(--color-text-primary)]'}`}>
                        {item}
                      </span>
                    </li>
                  ))}
                </ul>
              </div>

              <div class={`rounded-[var(--radius-xl)] border p-4 ${
                p.featured
                  ? 'border-[var(--color-border-ondark)] bg-[rgba(255,255,255,0.03)]'
                  : 'border-[var(--color-border)] bg-[var(--color-bg-surface-low)]'
              }`}>
                <p class={`text-xs font-semibold uppercase tracking-[0.06em] ${
                  p.featured ? 'text-[var(--color-text-ondark-soft)]' : 'text-[var(--color-text-tertiary)]'
                }`}>
                  Считать отдельно
                </p>
                <ul class="mt-3 space-y-2">
                  {p.separate.map((item) => (
                    <li class="flex items-start gap-2.5">
                      <svg class={`mt-0.5 shrink-0 ${p.featured ? 'text-[var(--color-text-ondark-soft)]' : 'text-[var(--color-text-tertiary)]'}`} width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="12" cy="12" r="10" />
                        <line x1="12" y1="8" x2="12" y2="12" />
                        <line x1="12" y1="16" x2="12.01" y2="16" />
                      </svg>
                      <span class={`text-sm leading-[1.5] ${p.featured ? 'text-[var(--color-text-ondark-mute)]' : 'text-[var(--color-text-secondary)]'}`}>
                        {item}
                      </span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>

            <button
              type="button"
              data-open-modal
              data-scenario="dont_know"
              class={`mt-auto inline-flex min-h-[48px] w-full items-center justify-center rounded-[var(--radius-md)] px-5 py-3 text-sm font-semibold transition-colors ${
                p.featured
                  ? 'bg-white text-[var(--color-bg-dark)] hover:bg-[var(--color-bg-secondary)]'
                  : 'bg-[var(--color-accent-primary)] text-white hover:bg-[var(--color-accent-hover)]'
              }`}
            >
              Подобрать проект дома
            </button>
          </div>
        </article>
      ))}
    </div>

    {/* Bottom note */}
    <div class="fade-in-up mt-10 md:mt-12">
      <div class="mx-auto max-w-[64rem] rounded-[var(--radius-2xl)] border border-[var(--color-border)] bg-[var(--color-bg-surface-low)] px-5 py-4 text-center shadow-[0_18px_40px_-34px_rgba(7,27,58,0.14)] md:px-6">
        <p class="mx-auto max-w-[60ch] text-sm text-[var(--color-text-tertiary)]">
        Это ориентировочные бюджеты. Точная цена зависит от участка, подрядчика, комплектации и ипотеки. Считаем на разборе — без давления и навязывания.
        </p>
      </div>
    </div>

  </div>
</section>
