---
import { Image } from 'astro:assets';
import irinaPhoto from '@/assets/irina-melnikova.png';

const bullets = [
  {
    icon: 'search',
    title: 'Проверка кредитной истории',
    text: 'Узнаем, что видят банки. Если есть проблемы — подскажем, как исправить.',
  },
  {
    icon: 'file',
    title: 'Подбор документов',
    text: 'Соберём полный пакет: справки, выписки, подтверждения. Без беготни.',
  },
  {
    icon: 'layers',
    title: 'Комбо-ипотека',
    text: 'Если лимита 6 млн не хватает — комбинируем семейную ипотеку с обычной.',
  },
];
---

<section
  id="section-mortgage"
  class="relative overflow-hidden bg-[var(--color-bg-secondary)] vn-section-padding"
>
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(8,116,196,0.12),transparent_34%),radial-gradient(circle_at_bottom_left,rgba(91,199,242,0.12),transparent_30%)]"
    aria-hidden="true"
  />

  <div class="site-container relative">
    <div class="overflow-hidden rounded-[var(--radius-2xl)] border border-[var(--color-border)] bg-[var(--color-bg-surface)] shadow-[0_30px_80px_-36px_rgba(7,27,58,0.24)]">
      <div class="relative px-6 py-6 sm:px-8 sm:py-8 lg:px-10 lg:py-10">
        <div
          class="pointer-events-none absolute inset-x-0 top-0 h-px bg-[linear-gradient(90deg,transparent,rgba(8,116,196,0.32),transparent)]"
          aria-hidden="true"
        />

        <div class="grid-12 items-stretch gap-y-8 lg:gap-y-0">
          <div class="col-span-12 lg:col-span-7">
            <div class="flex h-full flex-col rounded-[var(--radius-xl)] border border-[var(--color-border)] bg-[var(--color-bg-surface-low)] p-6 sm:p-8 lg:p-10">
              <span class="inline-flex w-fit items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-bg-surface)] px-4 py-2 text-xs font-semibold uppercase tracking-[0.06em] text-[var(--color-accent-primary)]">
                <span class="block h-px w-6 bg-[var(--color-accent-primary)]" />
                Ипотека на строительство
              </span>

              <h2 class="mt-5 max-w-[13ch] text-[28px] font-bold leading-[1.14] tracking-[-0.01em] text-[var(--color-text-primary)] md:text-[36px] lg:text-[42px]">
                Поможем получить одобрение по ипотеке <span class="text-[var(--color-accent-primary)]">6%</span>, даже если вам отказывали в банках
              </h2>

              <p class="mt-4 max-w-[52ch] text-base leading-relaxed text-[var(--color-text-secondary)] md:text-lg">
                Проверим кредитную историю, подберём документы и банки, которые реально одобряют. <strong class="text-[var(--color-text-primary)]">Бесплатно для клиента.</strong>
              </p>

              <div class="mt-8 flex flex-col items-start gap-4 sm:flex-row sm:flex-wrap sm:items-center">
                <button
                  type="button"
                  data-open-modal
                  data-scenario="mortgage"
                  class="inline-flex min-h-[48px] w-full items-center justify-center rounded-[var(--radius-md)] bg-[var(--color-accent-primary)] px-7 py-4 text-base font-semibold text-white transition-all duration-200 hover:-translate-y-px hover:bg-[var(--color-accent-hover)] sm:w-auto shadow-[0_12px_24px_-12px_rgba(8,116,196,0.56)]"
                >
                  Получить консультацию по ипотеке
                </button>

                <div class="inline-flex items-center gap-2 text-sm leading-snug text-[var(--color-text-secondary)]">
                  <svg
                    class="shrink-0 text-[var(--color-accent-primary)]"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                  </svg>
                  <span>Бесплатная консультация. Без обязательств.</span>
                </div>
              </div>
            </div>
          </div>

          <div class="col-span-12 lg:col-span-5">
            <aside class="relative flex h-full flex-col rounded-[var(--radius-xl)] bg-[var(--color-bg-dark)] p-4 sm:p-5">
              <div
                class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(91,199,242,0.16),transparent_34%),linear-gradient(180deg,rgba(255,255,255,0.04),transparent)]"
                aria-hidden="true"
              />

              <div class="relative flex h-full flex-col rounded-[calc(var(--radius-xl)-4px)] border border-[var(--color-border-ondark)] bg-[rgba(255,255,255,0.03)] p-3 sm:p-4">
                <div class="relative overflow-hidden rounded-[var(--radius-lg)]">
                  <div
                    class="pointer-events-none absolute inset-0 z-10 bg-[linear-gradient(180deg,transparent_58%,rgba(4,18,38,0.82)_100%)]"
                    aria-hidden="true"
                  />
                  <Image
                    src={irinaPhoto}
                    alt="Ирина Александровна — ипотечный брокер"
                    width={400}
                    height={500}
                    loading="lazy"
                    class="aspect-[4/5] w-full rounded-[var(--radius-lg)] object-cover"
                  />
                </div>

                <div class="relative -mt-14 z-20 mx-3 rounded-[var(--radius-lg)] border border-[var(--color-border-ondark)] bg-[rgba(7,27,58,0.92)] p-4 shadow-[0_18px_32px_-24px_rgba(0,0,0,0.65)] backdrop-blur-sm">
                  <p class="text-lg font-bold text-[var(--color-text-ondark)]">Ирина Александровна</p>
                  <p class="mt-0.5 text-sm text-[var(--color-text-ondark-mute)]">Ипотечный брокер</p>
                  <p class="mt-2 text-sm font-medium leading-relaxed text-[var(--color-accent-cyan)]">
                    Опыт более 5 лет · Эксперт по сложным случаям
                  </p>
                </div>
              </div>
            </aside>
          </div>
        </div>
      </div>

      <div class="border-t border-[var(--color-border)] bg-[var(--color-bg-dark)] px-6 py-6 sm:px-8 sm:py-8 lg:px-10">
        <ul class="grid grid-cols-1 gap-4 md:grid-cols-3 md:gap-5">
          {bullets.map((b, index) => (
            <li class="group flex h-full flex-col rounded-[var(--radius-xl)] border border-[var(--color-border-ondark)] bg-[rgba(255,255,255,0.04)] p-6 transition-all duration-200 hover:-translate-y-1 hover:border-[rgba(91,199,242,0.28)] hover:bg-[rgba(255,255,255,0.06)]">
              <div class="flex items-start justify-between gap-4">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-[var(--radius-md)] bg-[rgba(91,199,242,0.1)] text-[var(--color-accent-cyan)]">
                  <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    {b.icon === 'search' && (
                      <>
                        <circle cx="11" cy="11" r="8" />
                        <line x1="21" y1="21" x2="16.65" y2="16.65" />
                      </>
                    )}
                    {b.icon === 'file' && (
                      <>
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                        <polyline points="14 2 14 8 20 8" />
                      </>
                    )}
                    {b.icon === 'layers' && (
                      <>
                        <polygon points="12 2 2 7 12 12 22 7 12 2" />
                        <polyline points="2 17 12 22 22 17" />
                        <polyline points="2 12 12 17 22 12" />
                      </>
                    )}
                  </svg>
                </div>

                <span class="text-sm font-semibold tracking-[0.08em] text-[var(--color-text-ondark-soft)]">
                  0{index + 1}
                </span>
              </div>

              <h3 class="mt-5 text-base font-semibold leading-snug text-[var(--color-text-ondark)]">
                {b.title}
              </h3>

              <p class="mt-2 text-sm leading-[1.55] text-[var(--color-text-ondark-mute)]">
                {b.text}
              </p>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
