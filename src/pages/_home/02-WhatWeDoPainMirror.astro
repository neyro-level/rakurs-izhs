---
const tags = [
  'Ищете участок',
  'Сравниваете сметы',
  'Нужна ипотека 6%',
  'Не знаете, с чего начать',
];

const pains = [
  {
    title: 'Подрядчик возьмёт деньги и исчезнет',
    text: '10 800 обманутых семей по России. В Перми — 8 компаний в чёрном списке. Проверяем подрядчика до договора.',
  },
  {
    title: 'Смета вырастет в 2 раза',
    text: 'Разброс за одинаковый дом — от 3,5 до 6 млн. Разбираем построчно: фундамент, кровля, инженерия.',
  },
  {
    title: 'Участок не подойдёт под ипотеку',
    text: 'Охранные зоны, СНТ вместо ИЖС, без коммуникаций. Каждая пятая сделка — с проблемами. Проверяем до покупки.',
  },
];

const components = [
  { icon: 'map', title: '520+ участков в базе Ракурс' },
  { icon: 'bank', title: 'Ипотека 6% — расчёт до подрядчика' },
  { icon: 'search', title: 'Проверенный подрядчик по 6 критериям' },
  { icon: 'clipboard', title: 'Построчный разбор сметы' },
  { icon: 'handshake', title: 'Сопровождение до договора' },
];
---

<section
  id="section-whatwedo"
  data-review-id="home-whatwedo"
  data-review-title="Главная: с чего начать"
  data-review-path="src/pages/_home/02-WhatWeDoPainMirror.astro"
  class="relative overflow-hidden bg-[var(--color-bg-primary)]"
>
  <div class="site-container vn-section-padding relative">

    <!-- Zone 1: Header -->
    <div class="fade-in-up max-w-3xl">
      <!-- Eyebrow -->
      <span class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.06em] text-[var(--color-accent-primary)]">
        <span class="block w-6 h-px bg-[var(--color-accent-primary)]" />
        Сопровождение строительства
      </span>

      <!-- Self-identification tags -->
      <div class="mt-5 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="inline-flex items-center rounded-[var(--radius-pill)] bg-[var(--color-accent-soft)] px-3 py-1.5 text-xs font-medium text-[var(--color-accent-primary)]">
            {tag}
          </span>
        ))}
      </div>

      <!-- H2 -->
      <h2 class="mt-6 text-[28px] md:text-[36px] lg:text-[42px] font-bold leading-[1.14] tracking-[-0.01em] text-[var(--color-text-primary)]">
        Ошибка на старте стоит миллионы.<br class="hidden md:block" />
        <span class="text-[var(--color-accent-primary)]">Собираем решение:</span> участок, подрядчик, смета, ипотека
      </h2>

      <!-- Subtitle -->
      <p class="mt-4 text-base md:text-lg text-[var(--color-text-secondary)] leading-relaxed max-w-[58ch]">
        Проверяем и соединяем в понятный план до начала работ
      </p>
    </div>

    <!-- Zone 2: PainMirror cards -->
    <div class="mt-12 md:mt-16 grid grid-cols-1 md:grid-cols-3 gap-5 md:gap-6">
      {pains.map((p) => (
        <div class="fade-in-up group relative rounded-[var(--radius-lg)] bg-[var(--color-bg-surface)] border border-[var(--color-border)] p-6 md:p-7 transition-all duration-300 hover:shadow-[0_8px_32px_-8px_rgba(8,116,196,0.12)] hover:border-[var(--color-border-strong)]">
          <!-- Accent top line — always visible on mobile, hover on desktop -->
          <div class="absolute top-0 left-6 right-6 h-[2px] rounded-full bg-[var(--color-accent-primary)] opacity-60 md:opacity-0 md:group-hover:opacity-100 transition-opacity duration-300" />

          <!-- Content -->
          <div class="relative">
            <h3 class="text-lg font-semibold text-[var(--color-text-primary)] leading-snug">
              {p.title}
            </h3>
            <p class="mt-3 text-[15px] text-[var(--color-text-secondary)] leading-[1.5]">
              {p.text}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- Zone 3: Components dark strip -->
    <div class="fade-in-up mt-12 md:mt-16 rounded-[var(--radius-xl)] bg-[var(--color-bg-dark)] overflow-hidden relative">
      <!-- Decorative grid on dark -->
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true"
        style="background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px); background-size: 48px 48px;"
      />

      <div class="relative px-6 md:px-10 py-8 md:py-10">
        <!-- Section label -->
        <p class="text-xs font-semibold uppercase tracking-[0.06em] text-[var(--color-accent-cyan)] mb-6">
          Что входит в разбор
        </p>

        <!-- 5 components grid — titles only, no descriptions -->
        <div class="grid grid-cols-2 lg:grid-cols-5 gap-4 md:gap-4">
          {components.map((c) => (
            <div class="flex items-center gap-3">
              <!-- Icon -->
              <div class="flex items-center justify-center w-10 h-10 rounded-[var(--radius-md)] bg-[rgba(91,199,242,0.1)] shrink-0">
                {c.icon === 'map' && (
                  <svg class="text-[var(--color-accent-cyan)]" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                    <circle cx="12" cy="10" r="3" />
                  </svg>
                )}
                {c.icon === 'bank' && (
                  <svg class="text-[var(--color-accent-cyan)]" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="12" y1="1" x2="12" y2="23" />
                    <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                  </svg>
                )}
                {c.icon === 'search' && (
                  <svg class="text-[var(--color-accent-cyan)]" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8" />
                    <line x1="21" y1="21" x2="16.65" y2="16.65" />
                  </svg>
                )}
                {c.icon === 'clipboard' && (
                  <svg class="text-[var(--color-accent-cyan)]" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2" />
                    <rect x="8" y="2" width="8" height="4" rx="1" ry="1" />
                    <path d="M9 14l2 2 4-4" />
                  </svg>
                )}
                {c.icon === 'handshake' && (
                  <svg class="text-[var(--color-accent-cyan)]" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20.42 4.58a5.4 5.4 0 0 0-7.65 0l-.77.78-.77-.78a5.4 5.4 0 0 0-7.65 0C1.46 6.7 1.33 10.28 4 13l8 8 8-8c2.67-2.72 2.54-6.3.42-8.42z" />
                  </svg>
                )}
              </div>

              <!-- Title only -->
              <span class="text-sm font-semibold text-[var(--color-text-ondark)] leading-snug">
                {c.title}
              </span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- CTA + Microcopy -->
    <div class="fade-in-up mt-10 md:mt-12 flex flex-col items-start gap-3">
      <button
        type="button"
        data-open-modal
        data-scenario="search_land"
        class="w-full sm:w-auto inline-flex items-center justify-center rounded-[var(--radius-md)] bg-[var(--color-accent-primary)] text-white px-7 py-4 text-base font-semibold hover:bg-[var(--color-accent-hover)] transition-colors min-h-[48px] shadow-[0_4px_16px_-4px_rgba(8,116,196,0.4)]"
      >
        Получить разбор строительства
      </button>
      <p class="text-sm text-[var(--color-text-tertiary)] max-w-[48ch]">
        На любой стадии: ищете участок, сравниваете сметы или нужна ипотека 6%
      </p>
    </div>

  </div>
</section>
