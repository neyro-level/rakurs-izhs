---
import { EXPERT } from '@/lib/constants';

const phoneHref = `tel:${EXPERT.phone.replace(/[^\d+]/g, '')}`;
---

<div id="mobile-bottom-cta" class="vn-bottom-cta" role="complementary" aria-label="Быстрые действия" data-visible="true">
  <nav class="vn-bottom-cta__dock" aria-label="Быстрые действия">
    <button
      type="button"
      data-open-modal
      data-scenario="general"
      class="vn-bottom-cta__item"
    >
      <span class="vn-bottom-cta__icon" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="1.6"
             stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
      </span>
      <span class="vn-bottom-cta__label">Разбор</span>
    </button>

    <a
      href={phoneHref}
      class="vn-bottom-cta__item vn-bottom-cta__item--phone"
      aria-label={`Позвонить ${EXPERT.phone}`}
    >
      <span class="vn-bottom-cta__phone-orb" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="1.7"
             stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v2.1a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.12 3.3 2 2 0 0 1 4.11 1.1h2.11a2 2 0 0 1 2 1.72c.12.9.33 1.78.62 2.62a2 2 0 0 1-.45 2.11L7.5 8.44a16 16 0 0 0 6 6l.89-.89a2 2 0 0 1 2.11-.45c.84.29 1.72.5 2.62.62A2 2 0 0 1 22 16.92z"/>
        </svg>
      </span>
      <span class="vn-bottom-cta__label vn-bottom-cta__label--phone">Позвонить</span>
    </a>

    <a
      href="https://t.me/rtemii_nikulin"
      target="_blank"
      rel="noopener noreferrer"
      class="vn-bottom-cta__item"
    >
      <span class="vn-bottom-cta__icon" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="1.6"
             stroke-linecap="round" stroke-linejoin="round">
          <path d="m22 2-7 20-4-9-9-4 20-7z"/><path d="M22 2 11 13"/>
        </svg>
      </span>
      <span class="vn-bottom-cta__label">Telegram</span>
    </a>
  </nav>
</div>

<style>
  .vn-bottom-cta {
    display:          none;
    position:         fixed;
    bottom:           max(16px, calc(env(safe-area-inset-bottom) + 8px));
    left:             16px;
    right:            16px;
    z-index:          50;
    padding:          5px;
    background:       color-mix(in srgb, var(--color-bg-dark) 80%, transparent);
    backdrop-filter:  blur(28px) saturate(1.7);
    -webkit-backdrop-filter: blur(28px) saturate(1.7);
    border-radius:    20px;
    border:           1px solid color-mix(in srgb, var(--color-brand-racurs) 12%, transparent);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--color-text-ondark) 8%, transparent),
      0 8px 32px color-mix(in srgb, var(--color-bg-dark) 18%, transparent),
      0 2px 6px  color-mix(in srgb, var(--color-brand-racurs) 6%, transparent);
    opacity:          0;
    transform:        translateY(calc(100% + 32px));
    pointer-events:   none;
    transition:
      opacity   240ms ease,
      transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform, opacity;
  }

  .vn-bottom-cta[data-visible="true"] {
    opacity:        1;
    transform:      translateY(0);
    pointer-events: auto;
  }

  .vn-bottom-cta__dock {
    display:               grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    align-items:           center;
    gap:                   4px;
  }

  .vn-bottom-cta__item {
    display:         flex;
    flex-direction:  column;
    align-items:     center;
    justify-content: center;
    min-width:       0;
    min-height:      52px;
    padding:         9px 6px 7px;
    border-radius:   12px;
    color:           var(--color-text-ondark-mute);
    font-family:     var(--font-family-base);
    text-decoration: none;
    background:      transparent;
    border:          none;
    cursor:          pointer;
    box-shadow:      inset 0 0 0 1px color-mix(in srgb, var(--color-brand-racurs) 10%, transparent);
    transition:
      color      150ms ease,
      background 150ms ease,
      box-shadow 150ms ease;
  }

  .vn-bottom-cta__item:active {
    background: color-mix(in srgb, var(--color-brand-racurs) 10%, transparent);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-brand-racurs) 22%, transparent);
    color:      var(--color-text-ondark);
  }

  @media (hover: hover) {
    .vn-bottom-cta__item:hover {
      background: color-mix(in srgb, var(--color-brand-racurs) 6%, transparent);
      box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-brand-racurs) 16%, transparent);
      color:      var(--color-text-ondark);
    }
  }

  .vn-bottom-cta__item--phone .vn-bottom-cta__phone-orb {
    color: var(--color-accent-cyan);
  }

  .vn-bottom-cta__item--phone .vn-bottom-cta__label--phone {
    color:   var(--color-accent-cyan);
    opacity: 0.85;
  }

  .vn-bottom-cta__icon,
  .vn-bottom-cta__phone-orb {
    display:         inline-flex;
    align-items:     center;
    justify-content: center;
    width:           20px;
    height:          20px;
    color:           currentColor;
    flex-shrink:     0;
  }

  .vn-bottom-cta__label {
    display:        block;
    max-width:      100%;
    margin-top:     4px;
    overflow:       hidden;
    color:          currentColor;
    font-size:      10px;
    font-weight:    500;
    letter-spacing: 0.01em;
    line-height:    1;
    text-align:     center;
    text-overflow:  ellipsis;
    white-space:    nowrap;
  }

  @media (max-width: 1023px) {
    .vn-bottom-cta { display: block; }
  }

  @media (prefers-reduced-motion: reduce) {
    .vn-bottom-cta,
    .vn-bottom-cta__item { transition: none; }
  }
</style>

<script>
  const mobileDock = document.getElementById('mobile-bottom-cta');

  if (mobileDock) {
    let lastScrollY = window.scrollY;
    let idleTimer = 0;
    const minDelta = 6;
    const idleDelay = 520;
    const mobileQuery = window.matchMedia('(max-width: 1023px)');

    const showDock = () => {
      mobileDock.dataset.visible = 'true';
    };

    const hideDock = () => {
      mobileDock.dataset.visible = 'false';
    };

    const handleScroll = () => {
      if (!mobileQuery.matches) {
        showDock();
        return;
      }

      const currentScrollY = Math.max(window.scrollY, 0);
      const delta = currentScrollY - lastScrollY;

      window.clearTimeout(idleTimer);

      if (Math.abs(delta) > minDelta) {
        if (delta > 0 && currentScrollY > 80) {
          hideDock();
        } else {
          showDock();
        }
        lastScrollY = currentScrollY;
      }

      idleTimer = window.setTimeout(showDock, idleDelay);
    };

    showDock();
    window.addEventListener('scroll', handleScroll, { passive: true });
    window.addEventListener('resize', handleScroll);
  }
</script>
